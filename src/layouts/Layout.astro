---
interface Props {
  title: string;
  description?: string;
  image?: string;
  keywords?: string[];
  noindex?: boolean;
  additionalSchema?: object;
  hideFooter?: boolean;
  hideBanner?: boolean;
}

const defaultKeywords = [
  'instalaciones barcelona',
  'reformas barcelona',
  'electricista barcelona',
  'fontanero barcelona',
  'aire acondicionado barcelona',
  'calefaccion barcelona',
  'instalador autorizado barcelona',
  'reformas integrales barcelona',
  'mantenimiento instalaciones barcelona',
  'presupuesto reformas barcelona',
  'servicios de instalaciones barcelona',
  'servicios de reformas barcelona',
  'servicios de electricidad barcelona',
  'servicios de fontaneria barcelona',
  'servicios de climatizacion barcelona',
  'reformas pisos barcelona',
  'planificador de reformas',
  'estimador 3d reformas'
];

const {
  title = 'Servicios de Instalaciones y Reformas en Barcelona | IS INSTALACIONES',
  description = 'Servicios profesionales de instalaciones y reformas en Barcelona. Electricidad, fontaneria, climatizacion y reformas integrales con tecnicos autorizados, presupuesto gratuito y 2 anos de garantia.',
  image = '/img/logo.webp',
  keywords = defaultKeywords,
  noindex = false,
  additionalSchema,
  hideFooter = false,
  hideBanner = false
} = Astro.props;

const siteUrl = 'https://is-instalaciones.es';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const imageUrl = new URL(image, siteUrl).toString();

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${siteUrl}#localbusiness`,
  name: 'IS INSTALACIONES',
  image: imageUrl,
  url: canonicalURL.toString(),
  telephone: '+34637591736',
  email: 'isinstalacionesbcn@gmail.com',
  priceRange: 'EUR',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Barcelona',
    postalCode: '08001',
    addressRegion: 'Barcelona',
    addressCountry: 'ES'
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 41.3851,
    longitude: 2.1734
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '18:00'
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '09:00',
      closes: '14:00'
    }
  ],
  areaServed: [
    { '@type': 'City', name: 'Barcelona' },
    { '@type': 'City', name: "L'Hospitalet de Llobregat" },
    { '@type': 'City', name: 'Badalona' },
    { '@type': 'City', name: 'Santa Coloma de Gramenet' },
    { '@type': 'City', name: 'Cornella de Llobregat' }
  ],
  sameAs: [
    'https://g.page/isinstalaciones',
    'https://wa.me/34637591736'
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios de instalaciones y reformas',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Instalaciones electricas',
          description: 'Instalaciones electricas, cuadros, boletines y modernizacion de viviendas y locales en Barcelona.'
        }
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Fontaneria y saneamiento',
          description: 'Fontaneria, fugas, tuberias, calderas y saneamiento para viviendas y negocios.'
        }
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Climatizacion y calefaccion',
          description: 'Instalacion y mantenimiento de aire acondicionado, calefaccion y ventilacion.'
        }
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Reformas integrales',
          description: 'Reformas completas de pisos, cocinas, banos, oficinas y locales comerciales.'
        }
      }
    ]
  }
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl}#website`,
  url: siteUrl,
  name: 'IS INSTALACIONES',
  inLanguage: 'es-ES',
  publisher: { '@id': `${siteUrl}#localbusiness` }
};

import Footer from '../components/ui/Footer.astro';
import Header from '../components/ui/Header.astro';
import ChatBubble from '../components/ui/ChatBubble.astro';
import AnnouncementBanner from '../components/ui/AnnouncementBanner.astro';
import CookieBanner from '../components/ui/CookieBanner.astro';
import AnalyticsEvents from '../components/ui/AnalyticsEvents.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <script is:inline>window.dataLayer = window.dataLayer || [];</script>
    <script is:inline>
      const theme = localStorage.getItem('theme') || 'default';
      document.documentElement.setAttribute('data-theme', theme);
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(', ')} />
    <meta name="author" content="IS INSTALACIONES" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="theme-color" content="#046a53" />

    <link rel="alternate" type="text/plain" title="LLM Context" href="/llm.txt" />
    <link rel="alternate" type="text/plain" title="LLMs Context" href="/llms.txt" />
    <meta name="ai-content" content="Professional renovation and installation services in Barcelona. Licensed technicians, free quotes and 2-year warranty." />

    <meta name="geo.region" content="ES-CT" />
    <meta name="geo.placename" content="Barcelona" />
    <meta name="geo.position" content="41.3851;2.1734" />
    <meta name="ICBM" content="41.3851, 2.1734" />

    <meta property="og:locale" content="es_ES" />
    <link rel="alternate" hreflang="es-ES" href={canonicalURL} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/webp" sizes="any" href="/img/logo.webp" />
    <link rel="apple-touch-icon" href="/img/logo.webp" />
    <link rel="manifest" href="/site.manifest" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content="IS INSTALACIONES, servicios de instalaciones y reformas en Barcelona" />
    <meta property="og:site_name" content="IS.INSTALACIONES" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content="IS INSTALACIONES, servicios de instalaciones y reformas en Barcelona" />

    <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {additionalSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(additionalSchema)} />
    )}
  </head>
  <body>
    <Header />
    <slot />
    {!hideFooter && <Footer />}
    <ChatBubble />
    {!hideBanner && <AnnouncementBanner />}
    <CookieBanner />
    <AnalyticsEvents />
    <script is:inline>
      function initScrollAnimations() {
        const elements = document.querySelectorAll('[data-animate]');
        if (!elements.length) return;

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        elements.forEach((el) => observer.observe(el));

        document.querySelectorAll('[data-stagger]').forEach((container) => {
          const children = container.querySelectorAll(':scope > [data-animate]');
          children.forEach((child, i) => {
            child.style.setProperty('--stagger-index', String(i));
          });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initScrollAnimations);
      } else {
        initScrollAnimations();
      }

      document.addEventListener('astro:page-load', initScrollAnimations);
    </script>
  </body>
</html>
