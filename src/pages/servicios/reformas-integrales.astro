---
import Layout from '../../layouts/Layout.astro';
import Panoramic from '../../components/sections/Panoramic.astro';
import { Icon } from 'astro-icon/components';
import reformas from '../../assets/reformas-integrales.jpg'
const services = [
  {
    title: "Montaje de Pladur"
  },
  {
    title: "Carpintería de Aluminio"
  },
  {
    title: "Instalación de Ventanas"
  },
  {
    title: "Reformas de Vivienda"
  },
  {
    title: "Acabados en Construcción"
  },
  {title: "Instalación RJ-45"},

  {title: "Instalación de antenas"},
];

---

<Layout title="Servicios de Mantenimiento y Reformas - IS INSTALACIONES">
  
  <main class="pt-20">

  

      <Panoramic
      imagen="/trabajos/pladur-bano.jpeg"
      texto="Reformas Integrales"/>


    <section class="py-20">
      <div class="container mx-auto px-4">
        
        <div class="mb-12">
            <div data-animate="fade-left" class="cta-service-card bg-white p-6 md:p-8 rounded-2xl shadow-md border border-gray-100 border-l-4 border-l-primary relative overflow-hidden">
                <div class="cta-stat-shine"></div>
                <div class="relative z-[1]">
                  <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center">
                      <Icon name="lucide:list-checks" class="w-5 h-5 text-primary" />
                    </div>
                    <h2 class="text-xl font-bold text-slate-800">Nuestros Servicios</h2>
                  </div>
                  <ul class="space-y-3">
                    {services.map(service => (
                      <li class="flex items-start text-gray-600 text-sm leading-snug">
                        <Icon name="lucide:circle-check" class="w-4 h-4 text-primary mr-2.5 mt-0.5 flex-shrink-0" />
                        <h3>{service.title}</h3>
                      </li>
                    ))}
                  </ul>
                </div>
            </div>
        </div>

        <div class=" p-8 rounded-lg border border-primary/20 hover:border-primary/30 transition-colors">
          <h2 data-animate="fade-up" class="text-2xl text-center font-bold mb-4">Servicios de Reformas</h2>
          <div data-stagger class="grid md:grid-cols-3 gap-6">
            <div data-animate="fade-up" class="bg-white p-6 rounded-lg shadow-sm border border-primary/20 hover:border-primary/30 transition-all hover:shadow-md">
                <h3 class="font-bold text-xl mb-4">Servicios de Carpintería y Ventanas</h3>
                <ul class="space-y-2">
                  <li class="flex items-center">
                   ✓
                    Instalación de ventanas de aluminio
                  </li>
                  <li class="flex items-center">
                    ✓
                    Cerramientos de aluminio y PVC
                  </li>
                  <li class="flex items-center">
                    ✓
                    Montaje de puertas correderas
                  </li>
                  <li class="flex items-center">
                    ✓
                    Fabricación de estructuras a medida
                  </li>
                  <li class="flex items-center">
                   ✓
                    Cambio de cristales y persianas
                  </li>
                </ul>
              </div>
              
            
              <div data-animate="fade-up" class="bg-white p-6 rounded-lg shadow-sm border border-primary/20 hover:border-primary/30 transition-all hover:shadow-md">
                <h3 class="font-bold text-xl mb-4">Servicios de Albañilería y Reformas</h3>
                <ul class="space-y-2">
                  <li class="flex items-center">
                    ✓
                    Construcción de tabiques y muros
                  </li>
                  <li class="flex items-center">
                    ✓
                    Revestimiento de suelos y paredes
                  </li>
                  <li class="flex items-center">
                   ✓
                    Reforma de cocinas y baños
                  </li>
                  <li class="flex items-center">
                    ✓
                    Reparación de humedades y grietas
                  </li>
                  <li class="flex items-center">
                   ✓
                    Enfoscado y alicatado de superficies
                  </li>
                </ul>
              </div>
              
            
              <div data-animate="fade-up" class="bg-white p-6 rounded-lg shadow-sm border border-primary/20 hover:border-primary/30 transition-all hover:shadow-md">
                <h3 class="font-bold text-xl mb-4">Servicios de Pladur y Falsos Techos</h3>
                <ul class="space-y-2">
                    <li>✓ Instalación de tabiques de pladur</li>
                    <li>✓ Montaje de techos desmontables</li>
                    <li>✓ Aislamiento térmico y acústico</li>
                    <li>✓ Diseño de estanterías y muebles en pladur</li>
                    <li>✓ Reparación de estructuras de pladur</li>
                  </ul>
                  
              </div>
              

          </div>
        </div>
      </div>
    </section>
  </main>

</Layout>