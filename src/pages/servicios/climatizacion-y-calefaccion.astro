---
import Layout from "../../layouts/Layout.astro";
import Panoramic from "../../components/sections/Panoramic.astro";
import ContactSection from '../../components/contact/ContactSection.astro';
import ServiceDetail from '../../components/services/ServiceDetail.astro';
import ServiceProcess from '../../components/services/ServiceProcess.astro';
import ServiceCTABanner from '../../components/services/ServiceCTABanner.astro';
import { Icon } from 'astro-icon/components';

const services = [
  { title: "Instalación de aire acondicionado por conducto." },
  { title: "Instalación de suelo calefactable." },
  { title: "Climatización de viviendas." },
  { title: "Instalación de splits de aire acondicionado." },
  { title: "Carga de nitrogeno." },
];

// Sub-servicios en detalle (con imagen, copy persuasivo y palabras clave SEO)
const detalle = [
  {
    title: 'Aire acondicionado split y multisplit',
    image: '/trabajos/ac-exterior-mitsubishi.jpeg',
    text: 'Instalamos aire acondicionado split y multisplit de las mejores marcas en Barcelona. La solución más eficiente para climatizar una o varias estancias, con bajo consumo, funcionamiento silencioso y frío en verano y calor en invierno gracias a la bomba de calor.',
    bullets: ['Split y multisplit', 'Marcas líderes del mercado', 'Frío y calor (bomba de calor)', 'Bajo consumo y silencioso'],
  },
  {
    title: 'Aire acondicionado por conductos',
    image: '/trabajos/climatizacion-conductos.jpeg',
    text: 'Para viviendas grandes o locales, el aire acondicionado por conductos ofrece una climatización uniforme e integrada en el falso techo, sin equipos a la vista. Diseñamos la instalación a medida para repartir la temperatura de forma homogénea por toda la casa.',
    bullets: ['Climatización integrada y discreta', 'Reparto uniforme de temperatura', 'Ideal para viviendas grandes', 'Diseño a medida'],
  },
  {
    title: 'Calefacción y suelo radiante',
    image: '/trabajos/conductos-aislados.jpeg',
    text: 'Instalamos sistemas de calefacción y suelo radiante para un confort térmico óptimo en los meses fríos. El suelo radiante reparte el calor de forma uniforme y eficiente, con un consumo menor que los sistemas tradicionales.',
    bullets: ['Suelo radiante y calefactable', 'Calor uniforme y confortable', 'Mayor eficiencia energética', 'Compatible con aerotermia'],
  },
  {
    title: 'Mantenimiento y reparación',
    image: '/trabajos/mantenimiento-ac.jpeg',
    text: 'Ofrecemos mantenimiento preventivo y reparación de equipos de climatización: carga de gas refrigerante, limpieza, revisión y solución de averías. Con nuestros contratos de mantenimiento alargas la vida de tu equipo y evitas sustos en plena ola de calor.',
    bullets: ['Mantenimiento preventivo', 'Carga de gas refrigerante', 'Reparación de averías', 'Contratos de mantenimiento'],
  },
];

const incidencias = [
  { title: "Aire acondicionado no enfría", description: "Diagnóstico y reparación de sistemas que no enfrían correctamente." },
  { title: "Fugas de refrigerante", description: "Detección y reparación de fugas en el circuito de climatización." },
  { title: "Ruidos en el sistema", description: "Solución a vibraciones y ruidos anómalos en equipos de climatización." },
  { title: "Caldera no enciende", description: "Reparación y puesta a punto de calderas y sistemas de calefacción." },
];

const benefits = [
  { icon: "lucide:shield-check", title: "Técnicos Certificados", description: "Instaladores autorizados con certificación en gases fluorados." },
  { icon: "lucide:clock", title: "Respuesta Rápida", description: "Te respondemos en menos de 24 horas y cumplimos los plazos acordados." },
  { icon: "lucide:file-text", title: "Presupuesto Gratuito", description: "Estudio personalizado y presupuesto sin compromiso." },
  { icon: "lucide:award", title: "Garantía de 2 Años", description: "Garantía completa en mano de obra y materiales instalados." },
];

const faqItems = [
  {
    question: "¿Qué tipo de aire acondicionado es mejor para mi vivienda?",
    answer: "Depende del tamaño y distribución de tu vivienda. Para espacios pequeños o una sola habitación, un split es la opción más eficiente. Para viviendas grandes o varias estancias, recomendamos un sistema por conductos o multisplit. Nuestros técnicos realizan un estudio gratuito para recomendarte la mejor solución."
  },
  {
    question: "¿Con qué frecuencia debo revisar mi sistema de climatización?",
    answer: "Recomendamos una revisión anual antes de la temporada de mayor uso (primavera para aire acondicionado, otoño para calefacción). El mantenimiento preventivo prolonga la vida útil del equipo, reduce el consumo energético y previene averías costosas."
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<Layout
  title="Climatización y Calefacción en Barcelona - IS.INSTALACIONES"
  description="Instalación y reparación de aire acondicionado, calefacción y sistemas de climatización en Barcelona. Técnicos certificados y presupuesto gratuito."
  additionalSchema={faqSchema}
>

  <main class="pt-20">
    <Panoramic
    imagen="/trabajos/conductos-aislados.jpeg"
    texto="Servicios de Climatización"/>

    <section class="py-12 md:py-16" aria-label="Sección de servicios">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">

          <!-- Title + badge -->
          <div class="text-center mb-10">
            <div data-animate="fade-up" class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-sm font-medium mb-4">
              <Icon name="lucide:snowflake" class="w-4 h-4" />
              Climatización profesional en Barcelona
            </div>
            <h1 data-animate="fade-up" class="text-3xl md:text-4xl font-bold mb-6">Climatización y Calefacción Profesional en Barcelona</h1>
          </div>

          <!-- SEO text -->
          <div data-animate="fade-up" data-delay="200" class="max-w-4xl mx-auto mb-14 space-y-4">
            <p class="text-gray-600 text-base md:text-lg leading-relaxed">
              En <strong>IS Instalaciones</strong> somos expertos en <strong>climatización y calefacción en Barcelona</strong>. Nuestro equipo de técnicos certificados en gases fluorados se encarga de la instalación, mantenimiento y reparación de todo tipo de sistemas de climatización: aire acondicionado por conductos, splits, multisplits, suelos radiantes y calderas de última generación.
            </p>
            <p class="text-gray-600 text-base md:text-lg leading-relaxed">
              Trabajamos con las marcas líderes del mercado para garantizar equipos de máxima eficiencia energética. Nuestro servicio incluye un <strong>estudio personalizado</strong> de tu vivienda o local comercial para recomendar la solución de climatización más adecuada según las dimensiones, orientación y necesidades de uso, optimizando siempre el consumo energético.
            </p>
            <p class="text-gray-600 text-base md:text-lg leading-relaxed">
              Además, ofrecemos <strong>contratos de mantenimiento preventivo</strong> para mantener tus equipos a punto y resolver cualquier avería con la mayor rapidez. Si tu aire acondicionado no enfría, tu caldera no arranca o necesitas una instalación nueva, contacta con nosotros para un presupuesto gratuito y sin compromiso.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Servicios en detalle (banda gris) -->
    <ServiceDetail items={detalle} />

    <section class="py-12 md:py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">

          <!-- Services + Incidencias grid -->
          <div class="grid md:grid-cols-2 gap-8 mb-14">

            <!-- Left: Nuestros Servicios -->
            <div data-animate="fade-left" class="cta-service-card bg-white p-6 md:p-8 rounded-2xl shadow-md border border-gray-100 border-l-4 border-l-primary relative overflow-hidden">
              <div class="cta-stat-shine"></div>
              <div class="relative z-[1]">
                <div class="flex items-center gap-3 mb-6">
                  <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center">
                    <Icon name="lucide:list-checks" class="w-5 h-5 text-primary" />
                  </div>
                  <h2 class="text-xl font-bold text-slate-800">Nuestros Servicios</h2>
                </div>
                <ul class="space-y-3">
                  {services.map(service => (
                    <li class="flex items-start text-gray-600 text-sm leading-snug">
                      <Icon name="lucide:circle-check" class="w-4 h-4 text-primary mr-2.5 mt-0.5 flex-shrink-0" />
                      <h3>{service.title}</h3>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <!-- Right: Incidencias -->
            <div data-animate="fade-right">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 bg-amber-50 rounded-xl flex items-center justify-center">
                  <Icon name="lucide:alert-triangle" class="w-5 h-5 text-amber-500" />
                </div>
                <h2 class="text-xl font-bold text-slate-800">Incidencias Comunes</h2>
              </div>
              <div data-stagger class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {incidencias.map(incidencia => (
                  <div data-animate="fade-up" class="cta-service-card bg-white p-5 rounded-2xl shadow-md border border-gray-100 border-l-4 border-l-amber-400 relative overflow-hidden group">
                    <div class="cta-stat-shine"></div>
                    <div class="relative z-[1]">
                      <h3 class="font-bold text-slate-800 mb-1.5 group-hover:text-primary transition-colors">{incidencia.title}</h3>
                      <p class="text-gray-600 text-sm leading-snug">{incidencia.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Benefits -->
          <div class="mb-14">
            <div class="text-center mb-8">
              <div data-animate="fade-up" class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-sm font-medium mb-4">
                <Icon name="lucide:award" class="w-4 h-4" />
                Nuestras garantías
              </div>
              <h2 data-animate="fade-up" class="text-2xl md:text-3xl font-bold">¿Por qué Elegir IS Instalaciones?</h2>
            </div>
            <div data-stagger class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-5xl mx-auto">
              {benefits.map(benefit => (
                <div data-animate="fade-up" class="cta-service-card bg-white text-center p-6 rounded-2xl shadow-md border border-gray-100 relative overflow-hidden group">
                  <div class="cta-stat-shine"></div>
                  <div class="relative z-[1]">
                    <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform duration-300">
                      <Icon name={benefit.icon} class="w-6 h-6 text-primary" />
                    </div>
                    <h3 class="font-bold text-slate-800 mb-2">{benefit.title}</h3>
                    <p class="text-sm text-gray-600 leading-snug">{benefit.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- FAQ -->
          <div class="max-w-4xl mx-auto">
            <div class="text-center mb-8">
              <div data-animate="fade-up" class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-sm font-medium mb-4">
                <Icon name="lucide:help-circle" class="w-4 h-4" />
                Resolvemos tus dudas
              </div>
              <h2 data-animate="fade-up" class="text-2xl md:text-3xl font-bold">Preguntas Frecuentes</h2>
            </div>
            <div data-stagger class="space-y-4">
              {faqItems.map(item => (
                <div data-animate="fade-up" class="cta-service-card bg-white rounded-2xl p-6 shadow-md border border-gray-100 relative overflow-hidden group">
                  <div class="cta-stat-shine"></div>
                  <div class="relative z-[1]">
                    <h3 class="text-lg font-bold text-slate-800 mb-2 group-hover:text-primary transition-colors">{item.question}</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">{item.answer}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Proceso de trabajo -->
    <ServiceProcess servicio="tu sistema de climatización" />

    <!-- CTA -->
    <ServiceCTABanner
      title="¿Quieres instalar aire acondicionado o calefacción?"
      text="Pide tu presupuesto de climatización gratuito y sin compromiso. Técnicos certificados en gases fluorados, estudio personalizado y 2 años de garantía."
    />

    <ContactSection />
  </main>

</Layout>
