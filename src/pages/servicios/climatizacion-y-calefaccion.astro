---
import Layout from "../../layouts/Layout.astro";
import Panoramic from "../../components/sections/Panoramic.astro";
import ContactSection from '../../components/contact/ContactSection.astro';
import { Icon } from 'astro-icon/components';
import aire from '../../assets/tecnico-aire-acondicionado.png'

const services = [
  { title: "Instalación de aire acondicionado por conducto." },
  { title: "Instalación de suelo calefactable." },
  { title: "Climatización de viviendas." },
  { title: "Instalación de splits de aire acondicionado." },
  { title: "Carga de nitrogeno." },
];

const incidencias = [
  { title: "Aire acondicionado no enfría", description: "Diagnóstico y reparación de sistemas que no enfrían correctamente." },
  { title: "Fugas de refrigerante", description: "Detección y reparación de fugas en el circuito de climatización." },
  { title: "Ruidos en el sistema", description: "Solución a vibraciones y ruidos anómalos en equipos de climatización." },
  { title: "Caldera no enciende", description: "Reparación y puesta a punto de calderas y sistemas de calefacción." },
];

const benefits = [
  { icon: "lucide:shield-check", title: "Técnicos Certificados", description: "Instaladores autorizados con certificación en gases fluorados." },
  { icon: "lucide:clock", title: "Urgencias 24/7", description: "Servicio de emergencias de climatización disponible todo el año." },
  { icon: "lucide:file-text", title: "Presupuesto Gratuito", description: "Estudio personalizado y presupuesto sin compromiso." },
  { icon: "lucide:award", title: "Garantía de 2 Años", description: "Garantía completa en mano de obra y materiales instalados." },
];

const faqItems = [
  {
    question: "¿Qué tipo de aire acondicionado es mejor para mi vivienda?",
    answer: "Depende del tamaño y distribución de tu vivienda. Para espacios pequeños o una sola habitación, un split es la opción más eficiente. Para viviendas grandes o varias estancias, recomendamos un sistema por conductos o multisplit. Nuestros técnicos realizan un estudio gratuito para recomendarte la mejor solución."
  },
  {
    question: "¿Con qué frecuencia debo revisar mi sistema de climatización?",
    answer: "Recomendamos una revisión anual antes de la temporada de mayor uso (primavera para aire acondicionado, otoño para calefacción). El mantenimiento preventivo prolonga la vida útil del equipo, reduce el consumo energético y previene averías costosas."
  },
  {
    question: "¿Cuánto cuesta instalar aire acondicionado por conductos?",
    answer: "El coste de una instalación por conductos varía según la superficie, el número de salidas y la complejidad de la obra. Para una vivienda de 80-120m², los precios suelen oscilar entre 4.000€ y 8.000€ incluyendo equipo y mano de obra. Solicita tu presupuesto personalizado sin compromiso."
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<Layout
  title="Climatización y Calefacción en Barcelona - IS.INSTALACIONES"
  description="Instalación y reparación de aire acondicionado, calefacción y sistemas de climatización en Barcelona. Técnicos certificados, urgencias 24/7 y presupuesto gratuito."
  additionalSchema={faqSchema}
>

  <main class="pt-20">
    <Panoramic
    imagen={aire}
    texto="Servicios de Climatización"/>

    <section class="py-20">
      <div class="container mx-auto px-4">
        <h1 data-animate="fade-up" class="text-3xl md:text-4xl font-bold text-center mb-6">Climatización y Calefacción Profesional en Barcelona</h1>

        <div data-animate="fade-up" data-delay="200" class="max-w-4xl mx-auto mb-12">
          <p class="text-gray-600 text-base md:text-lg leading-relaxed mb-4">
            En <strong>IS Instalaciones</strong> somos expertos en <strong>climatización y calefacción en Barcelona</strong>. Nuestro equipo de técnicos certificados en gases fluorados se encarga de la instalación, mantenimiento y reparación de todo tipo de sistemas de climatización: aire acondicionado por conductos, splits, multisplits, suelos radiantes y calderas de última generación.
          </p>
          <p class="text-gray-600 text-base md:text-lg leading-relaxed mb-4">
            Trabajamos con las marcas líderes del mercado para garantizar equipos de máxima eficiencia energética. Nuestro servicio incluye un <strong>estudio personalizado</strong> de tu vivienda o local comercial para recomendar la solución de climatización más adecuada según las dimensiones, orientación y necesidades de uso, optimizando siempre el consumo energético.
          </p>
          <p class="text-gray-600 text-base md:text-lg leading-relaxed">
            Además, ofrecemos <strong>contratos de mantenimiento preventivo</strong> y un servicio de urgencias 24/7 para resolver cualquier avería con la mayor rapidez. Si tu aire acondicionado no enfría, tu caldera no arranca o necesitas una instalación nueva, contacta con nosotros para un presupuesto gratuito y sin compromiso.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 mb-12">
          <div data-animate="fade-left">
            <h2 class="text-2xl font-bold mb-4">Nuestros Servicios</h2>
            <ul class="space-y-2">
              {services.map(service => (
                <li class="flex items-center text-gray-600">
                  <Icon name="lucide:check" class="w-4 h-4 text-primary mr-2 flex-shrink-0" />
                  <h3>{service.title}</h3>
                </li>
              ))}
            </ul>
          </div>

          <div data-animate="fade-right">
            <h2 class="text-2xl font-bold mb-4">Incidencias Comunes</h2>
            <div data-stagger class="grid md:grid-cols-1 lg:grid-cols-2 gap-6">
              {incidencias.map(incidencia => (
                <div data-animate="fade-up" class="bg-white p-6 rounded-lg shadow-md border border-primary/20 hover:border-primary/30 transition-all hover:shadow-lg">
                  <h3 class="text-base lg:text-2xl md:text-base sm:text-base font-bold mb-2">{incidencia.title}</h3>
                  <p class="text-gray-600 lg:text-lg md:text-base">{incidencia.description}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Por qué Elegir IS Instalaciones -->
        <div class="max-w-5xl mx-auto mb-12">
          <h2 data-animate="fade-up" class="text-2xl md:text-3xl font-bold text-center mb-8">¿Por qué Elegir IS Instalaciones?</h2>
          <div data-stagger class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {benefits.map(benefit => (
              <div data-animate="fade-up" class="text-center p-6 bg-white rounded-lg shadow-md border border-primary/20 hover:border-primary/30 transition-all hover:shadow-lg">
                <Icon name={benefit.icon} class="w-8 h-8 text-primary mx-auto mb-3" />
                <h3 class="font-bold mb-2">{benefit.title}</h3>
                <p class="text-sm text-gray-600">{benefit.description}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- FAQ -->
        <div class="max-w-4xl mx-auto">
          <h2 data-animate="fade-up" class="text-2xl md:text-3xl font-bold text-center mb-8">Preguntas Frecuentes</h2>
          <div data-stagger class="space-y-6">
            {faqItems.map(item => (
              <div data-animate="fade-up" class="bg-white rounded-lg p-6 shadow-md hover:shadow-lg transition-shadow">
                <h3 class="text-lg font-bold mb-3">{item.question}</h3>
                <p class="text-gray-600">{item.answer}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <ContactSection />
  </main>

</Layout>
