---
import Layout from '../../layouts/Layout.astro';
import Panoramic from '../../components/sections/Panoramic.astro';
import ContactSection from '../../components/contact/ContactSection.astro';
import ServiceDetail from '../../components/services/ServiceDetail.astro';
import ServiceProcess from '../../components/services/ServiceProcess.astro';
import ServiceCTABanner from '../../components/services/ServiceCTABanner.astro';
import { Icon } from 'astro-icon/components';

const services = [
  { title: "Instalación electrica de baja tensión." },
  { title: "Centralización de contadores." },
  { title: "Montante electrico." },
  { title: "Instalación de punto tierra." },
  { title: "Instalación general de viviendas o edificios." },
];

// Sub-servicios en detalle (con imagen, copy persuasivo y palabras clave SEO)
const detalle = [
  {
    title: 'Instalación eléctrica completa de viviendas y locales',
    image: '/trabajos/reforma-electricidad.jpeg',
    text: 'Realizamos la instalación eléctrica completa de pisos, casas y locales en Barcelona, cumpliendo siempre la normativa REBT. Desde el cableado y los mecanismos hasta la puesta a tierra, dejamos tu instalación segura, certificada y lista para el día a día.',
    bullets: ['Cableado y mecanismos', 'Puesta a tierra', 'Cumplimiento normativa REBT', 'Locales y viviendas nuevas'],
  },
  {
    title: 'Cuadros eléctricos y protecciones',
    image: '/trabajos/montaje_fusibles.jpeg',
    text: 'Instalamos y renovamos cuadros eléctricos con todas las protecciones (diferenciales y magnetotérmicos) para evitar sobrecargas y cortocircuitos. Protege tu hogar y tus electrodomésticos con una instalación moderna y segura.',
    bullets: ['Diferenciales y magnetotérmicos', 'Ampliación de potencia', 'Renovación de cuadros antiguos', 'Protección contra sobrecargas'],
  },
  {
    title: 'Centralización de contadores y boletines (CIE)',
    image: '/trabajos/contadores-electricos.jpeg',
    text: 'Tramitamos el boletín eléctrico (CIE), obligatorio para dar de alta o aumentar la potencia, y realizamos la centralización de contadores en comunidades y edificios. Te ayudamos con todo el papeleo para que el alta sea rápida y sin complicaciones.',
    bullets: ['Boletín eléctrico (CIE)', 'Alta y aumento de potencia', 'Centralización de contadores', 'Montante eléctrico'],
  },
  {
    title: 'Iluminación LED, porteros y automatismos',
    image: '/trabajos/instalacion-interfono.jpeg',
    text: 'Renueva tu iluminación con LED de bajo consumo y reduce tu factura de luz. Instalamos también porteros automáticos, videoporteros e interfonos para mejorar la comodidad y la seguridad de tu hogar o comunidad.',
    bullets: ['Iluminación LED de bajo consumo', 'Porteros y videoporteros', 'Interfonos y automatismos', 'Ahorro energético'],
  },
];

const incidencias = [
  { title: "Cortocircuitos", description: "Solución rápida y segura para problemas eléctricos." },
  { title: "Sobrecarga", description: "Diagnóstico y reparación de sistemas sobrecargados." },
  { title: "Fallos de Iluminación", description: "Reparación de sistemas de iluminación defectuosos." },
  { title: "Instalaciones Antiguas", description: "Actualización de instalaciones obsoletas." },
];

const benefits = [
  { icon: "lucide:shield-check", title: "Técnicos Autorizados", description: "Todos nuestros electricistas cuentan con las certificaciones oficiales vigentes." },
  { icon: "lucide:clock", title: "Urgencias 24/7", description: "Servicio de emergencias eléctricas disponible todos los días del año." },
  { icon: "lucide:file-text", title: "Presupuesto Gratuito", description: "Realizamos diagnóstico y presupuesto sin compromiso en tu domicilio." },
  { icon: "lucide:award", title: "Garantía de 2 Años", description: "Todos nuestros trabajos están cubiertos por garantía de mano de obra y materiales." },
];

const faqItems = [
  {
    question: "¿Qué incluye el servicio de urgencias eléctricas?",
    answer: "Nuestro servicio de urgencias 24/7 cubre cortocircuitos, caídas de tensión, fallos en el cuadro eléctrico, y cualquier avería que ponga en riesgo la seguridad de tu hogar. Garantizamos una respuesta en menos de 2 horas en Barcelona y área metropolitana."
  },
  {
    question: "¿Necesito el boletín eléctrico para mi vivienda?",
    answer: "El boletín eléctrico (CIE) es obligatorio para dar de alta o aumentar la potencia del suministro eléctrico, y también se requiere en compraventas y reformas. En IS Instalaciones tramitamos el boletín eléctrico tras verificar que la instalación cumple con la normativa REBT."
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<Layout
  title="Instalaciones Eléctricas Profesionales en Barcelona - IS.INSTALACIONES"
  description="Servicios de instalaciones eléctricas en Barcelona: reformas, cuadros eléctricos, iluminación LED, boletines y urgencias 24/7. Técnicos autorizados con más de 8 años de experiencia."
  additionalSchema={faqSchema}
>

  <main class="pt-10" id="electricidad">
    <!-- Hero Section -->
    <Panoramic
    imagen="/trabajos/contadores-electricos.jpeg"
    texto="Servicios de Electricidad"/>

    <!-- Services Section -->
    <section class="py-12 md:py-16" aria-label="Sección de servicios">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">

          <!-- Title + badge -->
          <div class="text-center mb-10">
            <div data-animate="fade-up" class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-sm font-medium mb-4">
              <Icon name="lucide:zap" class="w-4 h-4" />
              Electricistas autorizados en Barcelona
            </div>
            <h1 data-animate="fade-up" class="text-3xl md:text-4xl font-bold mb-6">Instalaciones Eléctricas Profesionales en Barcelona</h1>
          </div>

          <!-- SEO text -->
          <div data-animate="fade-up" data-delay="200" class="max-w-4xl mx-auto mb-14 space-y-4">
            <p class="text-gray-600 text-base md:text-lg leading-relaxed">
              En <strong>IS Instalaciones</strong> somos especialistas en todo tipo de <strong>instalaciones eléctricas en Barcelona</strong> y área metropolitana. Con más de 8 años de experiencia, nuestro equipo de electricistas autorizados se encarga de proyectos residenciales, comerciales e industriales, garantizando siempre el cumplimiento de la normativa REBT vigente y la máxima seguridad en cada intervención.
            </p>
            <p class="text-gray-600 text-base md:text-lg leading-relaxed">
              Desde la <strong>instalación eléctrica completa</strong> de una vivienda nueva hasta la actualización de sistemas antiguos, pasando por la centralización de contadores y la instalación de iluminación LED de bajo consumo, cubrimos todas las necesidades eléctricas de tu hogar o negocio. Trabajamos con materiales de primeras marcas y ofrecemos soluciones orientadas a la eficiencia energética para reducir tu factura eléctrica.
            </p>
            <p class="text-gray-600 text-base md:text-lg leading-relaxed">
              Disponemos de un <strong>servicio de urgencias eléctricas 24/7</strong> para resolver cualquier avería con rapidez y profesionalidad. No importa la hora ni el día: si tienes un problema eléctrico, estamos a tu disposición. Solicita tu presupuesto sin compromiso y descubre por qué cientos de clientes en Barcelona confían en nosotros.
            </p>
          </div>

          <!-- Servicios en detalle -->
          <ServiceDetail items={detalle} />

          <!-- Services + Incidencias grid -->
          <div class="grid md:grid-cols-2 gap-8 mb-14">

            <!-- Left: Nuestros Servicios -->
            <div data-animate="fade-left" class="cta-service-card bg-white p-6 md:p-8 rounded-2xl shadow-md border border-gray-100 border-l-4 border-l-primary relative overflow-hidden">
              <div class="cta-stat-shine"></div>
              <div class="relative z-[1]">
                <div class="flex items-center gap-3 mb-6">
                  <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center">
                    <Icon name="lucide:list-checks" class="w-5 h-5 text-primary" />
                  </div>
                  <h2 class="text-xl font-bold text-slate-800">Nuestros Servicios</h2>
                </div>
                <ul class="space-y-3">
                  {services.map(service => (
                    <li class="flex items-start text-gray-600 text-sm leading-snug">
                      <Icon name="lucide:circle-check" class="w-4 h-4 text-primary mr-2.5 mt-0.5 flex-shrink-0" />
                      <h3>{service.title}</h3>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <!-- Right: Incidencias -->
            <div data-animate="fade-right">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 bg-amber-50 rounded-xl flex items-center justify-center">
                  <Icon name="lucide:alert-triangle" class="w-5 h-5 text-amber-500" />
                </div>
                <h2 class="text-xl font-bold text-slate-800">Incidencias Comunes</h2>
              </div>
              <div data-stagger class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {incidencias.map(incidencia => (
                  <div data-animate="fade-up" class="cta-service-card bg-white p-5 rounded-2xl shadow-md border border-gray-100 border-l-4 border-l-amber-400 relative overflow-hidden group">
                    <div class="cta-stat-shine"></div>
                    <div class="relative z-[1]">
                      <h3 class="font-bold text-slate-800 mb-1.5 group-hover:text-primary transition-colors">{incidencia.title}</h3>
                      <p class="text-gray-600 text-sm leading-snug">{incidencia.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Benefits -->
          <div class="mb-14">
            <div class="text-center mb-8">
              <div data-animate="fade-up" class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-sm font-medium mb-4">
                <Icon name="lucide:award" class="w-4 h-4" />
                Nuestras garantías
              </div>
              <h2 data-animate="fade-up" class="text-2xl md:text-3xl font-bold">¿Por qué Elegir IS Instalaciones?</h2>
            </div>
            <div data-stagger class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-5xl mx-auto">
              {benefits.map(benefit => (
                <div data-animate="fade-up" class="cta-service-card bg-white text-center p-6 rounded-2xl shadow-md border border-gray-100 relative overflow-hidden group">
                  <div class="cta-stat-shine"></div>
                  <div class="relative z-[1]">
                    <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform duration-300">
                      <Icon name={benefit.icon} class="w-6 h-6 text-primary" />
                    </div>
                    <h3 class="font-bold text-slate-800 mb-2">{benefit.title}</h3>
                    <p class="text-sm text-gray-600 leading-snug">{benefit.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- FAQ -->
          <div class="max-w-4xl mx-auto">
            <div class="text-center mb-8">
              <div data-animate="fade-up" class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-sm font-medium mb-4">
                <Icon name="lucide:help-circle" class="w-4 h-4" />
                Resolvemos tus dudas
              </div>
              <h2 data-animate="fade-up" class="text-2xl md:text-3xl font-bold">Preguntas Frecuentes</h2>
            </div>
            <div data-stagger class="space-y-4">
              {faqItems.map(item => (
                <div data-animate="fade-up" class="cta-service-card bg-white rounded-2xl p-6 shadow-md border border-gray-100 relative overflow-hidden group">
                  <div class="cta-stat-shine"></div>
                  <div class="relative z-[1]">
                    <h3 class="text-lg font-bold text-slate-800 mb-2 group-hover:text-primary transition-colors">{item.question}</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">{item.answer}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Proceso de trabajo -->
    <ServiceProcess servicio="tu instalación eléctrica" />

    <!-- CTA -->
    <ServiceCTABanner
      title="¿Necesitas un electricista en Barcelona?"
      text="Pide tu presupuesto eléctrico gratuito y sin compromiso. Técnicos autorizados, urgencias 24/7 y trabajo garantizado 2 años."
    />

    <ContactSection />
  </main>

</Layout>
