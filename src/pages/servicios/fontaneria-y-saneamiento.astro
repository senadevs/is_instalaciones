---
import Layout from '../../layouts/Layout.astro';
import Panoramic from '../../components/sections/Panoramic.astro';
import ContactSection from '../../components/contact/ContactSection.astro';
import { Icon } from 'astro-icon/components';
import fontanero from '../../assets/fontanero.jpg'

const services = [
  { title: "Instalación de agua." },
  { title: "Acomedida de aguas general." },
  { title: "Instalación de calderas termo electricas." },
  { title: "Instalación de calderas aerotermicas." },
  { title: "Instalación de circuito de agua fria y caliente." },
];

const incidencias = [
  { title: "Fugas de agua", description: "Solución rapida y segura para problemas de agua." },
  { title: "Atascos", description: "Diagnostico y reparación de sistemas con atascos." },
  { title: "Baja presion", description: "Solución a problemas de presión de agua." },
  { title: "Grifos defectuosos", description: "Reparación y sustitución de grifería." },
];

const benefits = [
  { icon: "lucide:shield-check", title: "Fontaneros Autorizados", description: "Profesionales con certificación oficial para todas las intervenciones." },
  { icon: "lucide:clock", title: "Urgencias 24/7", description: "Servicio de emergencias de fontanería disponible los 365 días del año." },
  { icon: "lucide:file-text", title: "Presupuesto Gratuito", description: "Diagnóstico y presupuesto detallado sin compromiso en tu domicilio." },
  { icon: "lucide:award", title: "Garantía de 2 Años", description: "Todos los trabajos cubiertos por garantía de mano de obra y materiales." },
];

const faqItems = [
  {
    question: "¿Cómo detectar una fuga de agua oculta en mi vivienda?",
    answer: "Las señales más comunes son manchas de humedad en paredes o techos, aumento inexplicable en la factura del agua, y sonido de agua corriendo cuando todos los grifos están cerrados. En IS Instalaciones utilizamos equipos de detección profesional para localizar fugas sin necesidad de realizar obras innecesarias."
  },
  {
    question: "¿Cuánto cuesta cambiar las tuberías de una vivienda?",
    answer: "El coste depende del tipo de tubería, la extensión de la instalación y la accesibilidad. Para una vivienda de 80-100m², el cambio completo de tuberías suele oscilar entre 2.500€ y 5.000€. Ofrecemos presupuestos personalizados tras una visita técnica gratuita."
  },
  {
    question: "¿Qué tipo de caldera recomiendan instalar?",
    answer: "Recomendamos calderas de condensación o sistemas aerotérmicos por su alta eficiencia energética y menor impacto ambiental. La elección depende de las características de tu vivienda, el consumo estimado y tu presupuesto. Nuestros técnicos te asesoran sin compromiso."
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<Layout
  title="Servicios de Fontanería y Saneamiento en Barcelona - IS.INSTALACIONES"
  description="Fontaneros profesionales en Barcelona: instalaciones de agua, detección de fugas, cambio de tuberías, calderas y urgencias 24/7. Más de 8 años de experiencia."
  additionalSchema={faqSchema}
>

  <main class="pt-20">
    <Panoramic
    imagen={fontanero},
    texto="Servicios de Fontanería"/>

    <section class="py-20">
      <div class="container mx-auto px-4">
        <h1 data-animate="fade-up" class="text-3xl md:text-4xl font-bold text-center mb-6">Servicios de Fontanería y Saneamiento en Barcelona</h1>

        <div data-animate="fade-up" data-delay="200" class="max-w-4xl mx-auto mb-12">
          <p class="text-gray-600 text-base md:text-lg leading-relaxed mb-4">
            En <strong>IS Instalaciones</strong> ofrecemos servicios completos de <strong>fontanería y saneamiento en Barcelona</strong> y área metropolitana. Nuestro equipo de fontaneros autorizados cuenta con más de 8 años de experiencia resolviendo todo tipo de incidencias, desde fugas de agua y atascos hasta la instalación completa de sistemas sanitarios en viviendas y locales comerciales.
          </p>
          <p class="text-gray-600 text-base md:text-lg leading-relaxed mb-4">
            Realizamos <strong>instalaciones de agua fría y caliente</strong>, acometidas generales, montaje de calderas termoeléctricas y aerotérmicas, así como la sustitución integral de tuberías antiguas por materiales modernos de mayor durabilidad. Utilizamos técnicas de detección de fugas no invasivas para minimizar las obras en tu hogar.
          </p>
          <p class="text-gray-600 text-base md:text-lg leading-relaxed">
            Contamos con un <strong>servicio de urgencias de fontanería 24/7</strong> para atender averías que no pueden esperar: fugas, roturas de tuberías, problemas con la caldera o atascos severos. Solicita tu presupuesto gratuito y descubre por qué somos el fontanero de confianza de cientos de hogares en Barcelona.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 mb-12">
          <div data-animate="fade-left">
            <h2 class="text-2xl font-bold mb-4">Nuestros Servicios</h2>
            <ul class="space-y-2">
              {services.map(service => (
                <li class="flex items-center text-gray-600">
                  <Icon name="lucide:check" class="w-4 h-4 text-primary mr-2 flex-shrink-0" />
                  <h3>{service.title}</h3>
                </li>
              ))}
            </ul>
          </div>

          <div data-animate="fade-right">
            <h2 class="text-2xl font-bold mb-4">Incidencias Comunes</h2>
            <div data-stagger class="grid md:grid-cols-1 lg:grid-cols-2 gap-6">
              {incidencias.map(incidencia => (
                <div data-animate="fade-up" class="bg-white p-6 rounded-lg shadow-md border border-primary/20 hover:border-primary/30 transition-all hover:shadow-lg">
                  <h3 class="text-base lg:text-2xl md:text-base sm:text-base font-bold mb-2">{incidencia.title}</h3>
                  <p class="text-gray-600 lg:text-lg md:text-base">{incidencia.description}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Por qué Elegir IS Instalaciones -->
        <div class="max-w-5xl mx-auto mb-12">
          <h2 data-animate="fade-up" class="text-2xl md:text-3xl font-bold text-center mb-8">¿Por qué Elegir IS Instalaciones?</h2>
          <div data-stagger class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {benefits.map(benefit => (
              <div data-animate="fade-up" class="text-center p-6 bg-white rounded-lg shadow-md border border-primary/20 hover:border-primary/30 transition-all hover:shadow-lg">
                <Icon name={benefit.icon} class="w-8 h-8 text-primary mx-auto mb-3" />
                <h3 class="font-bold mb-2">{benefit.title}</h3>
                <p class="text-sm text-gray-600">{benefit.description}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- FAQ -->
        <div class="max-w-4xl mx-auto">
          <h2 data-animate="fade-up" class="text-2xl md:text-3xl font-bold text-center mb-8">Preguntas Frecuentes</h2>
          <div data-stagger class="space-y-6">
            {faqItems.map(item => (
              <div data-animate="fade-up" class="bg-white rounded-lg p-6 shadow-md hover:shadow-lg transition-shadow">
                <h3 class="text-lg font-bold mb-3">{item.question}</h3>
                <p class="text-gray-600">{item.answer}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <ContactSection />
  </main>

</Layout>
