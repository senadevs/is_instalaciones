---
import Layout from '../../layouts/Layout.astro';
import Panoramic from '../../components/sections/Panoramic.astro';
import ContactSection from '../../components/contact/ContactSection.astro';
import ServiceDetail from '../../components/services/ServiceDetail.astro';
import ServiceProcess from '../../components/services/ServiceProcess.astro';
import ServiceCTABanner from '../../components/services/ServiceCTABanner.astro';
import { Icon } from 'astro-icon/components';

const services = [
  { title: "Instalación de agua." },
  { title: "Acomedida de aguas general." },
  { title: "Instalación de calderas termo electricas." },
  { title: "Instalación de calderas aerotermicas." },
  { title: "Instalación de circuito de agua fria y caliente." },
];

// Sub-servicios en detalle (con imagen, copy persuasivo y palabras clave SEO)
const detalle = [
  {
    title: 'Instalación de agua fría y caliente',
    image: '/trabajos/fontaneria-tuberias.jpeg',
    text: 'Instalamos circuitos completos de agua fría y caliente en viviendas y locales de Barcelona, además de la acometida general. Utilizamos materiales de máxima durabilidad para garantizar una instalación de fontanería fiable, sin fugas y con buena presión en todos los puntos.',
    bullets: ['Circuito de agua fría y caliente', 'Acometida general de aguas', 'Materiales de larga duración', 'Viviendas y locales'],
  },
  {
    title: 'Detección y reparación de fugas',
    image: '/trabajos/fontaneria-fregadero.jpeg',
    text: 'Localizamos fugas de agua ocultas con equipos de detección no invasivos, sin romper más de lo necesario. Solucionamos humedades, goteos y roturas de tubería con rapidez para frenar el daño y el gasto en tu factura del agua.',
    bullets: ['Detección sin obras', 'Reparación de humedades', 'Roturas de tubería', 'Reparación rápida de fugas'],
  },
  {
    title: 'Calderas, termos y aerotermia',
    image: '/trabajos/fontaneria-contadores.jpeg',
    text: 'Instalamos y sustituimos calderas de condensación, termos eléctricos y sistemas aerotérmicos de alta eficiencia. Te asesoramos para elegir el equipo que más ahorra según tu vivienda, reduciendo tu consumo y tu factura energética.',
    bullets: ['Calderas de condensación', 'Termos eléctricos', 'Sistemas aerotérmicos', 'Asesoramiento en eficiencia'],
  },
  {
    title: 'Cambio de tuberías y desatascos',
    image: '/trabajos/fontaneria-tuberias.jpeg',
    text: 'Sustituimos tuberías antiguas por instalaciones modernas y resolvemos atascos y problemas de saneamiento. Recuperamos la presión del agua y dejamos tu red de desagües funcionando como el primer día.',
    bullets: ['Cambio integral de tuberías', 'Desatascos y saneamiento', 'Recuperación de presión', 'Sustitución de grifería y sanitarios'],
  },
];

const incidencias = [
  { title: "Fugas de agua", description: "Solución rapida y segura para problemas de agua." },
  { title: "Atascos", description: "Diagnostico y reparación de sistemas con atascos." },
  { title: "Baja presion", description: "Solución a problemas de presión de agua." },
  { title: "Grifos defectuosos", description: "Reparación y sustitución de grifería." },
];

const benefits = [
  { icon: "lucide:shield-check", title: "Fontaneros Autorizados", description: "Profesionales con certificación oficial para todas las intervenciones." },
  { icon: "lucide:clock", title: "Respuesta Rápida", description: "Te respondemos en menos de 24 horas y resolvemos las averías con agilidad." },
  { icon: "lucide:file-text", title: "Presupuesto Gratuito", description: "Diagnóstico y presupuesto detallado sin compromiso en tu domicilio." },
  { icon: "lucide:award", title: "Garantía de 2 Años", description: "Todos los trabajos cubiertos por garantía de mano de obra y materiales." },
];

const faqItems = [
  {
    question: "¿Cómo detectar una fuga de agua oculta en mi vivienda?",
    answer: "Las señales más comunes son manchas de humedad en paredes o techos, aumento inexplicable en la factura del agua, y sonido de agua corriendo cuando todos los grifos están cerrados. En IS Instalaciones utilizamos equipos de detección profesional para localizar fugas sin necesidad de realizar obras innecesarias."
  },
  {
    question: "¿Qué tipo de caldera recomiendan instalar?",
    answer: "Recomendamos calderas de condensación o sistemas aerotérmicos por su alta eficiencia energética y menor impacto ambiental. La elección depende de las características de tu vivienda, el consumo estimado y tu presupuesto. Nuestros técnicos te asesoran sin compromiso."
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<Layout
  title="Servicios de Fontanería y Saneamiento en Barcelona - IS.INSTALACIONES"
  description="Fontaneros profesionales en Barcelona: instalaciones de agua, detección de fugas, cambio de tuberías y calderas. Más de 8 años de experiencia."
  additionalSchema={faqSchema}
>

  <main class="pt-20">
    <Panoramic
    imagen="/trabajos/fontaneria-contadores.jpeg"
    texto="Servicios de Fontanería"/>

    <section class="py-12 md:py-16" aria-label="Sección de servicios">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">

          <!-- Title + badge -->
          <div class="text-center mb-10">
            <div data-animate="fade-up" class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-sm font-medium mb-4">
              <Icon name="lucide:droplets" class="w-4 h-4" />
              Fontaneros profesionales en Barcelona
            </div>
            <h1 data-animate="fade-up" class="text-3xl md:text-4xl font-bold mb-6">Servicios de Fontanería y Saneamiento en Barcelona</h1>
          </div>

          <!-- SEO text -->
          <div data-animate="fade-up" data-delay="200" class="max-w-4xl mx-auto mb-14 space-y-4">
            <p class="text-gray-600 text-base md:text-lg leading-relaxed">
              En <strong>IS Instalaciones</strong> ofrecemos servicios completos de <strong>fontanería y saneamiento en Barcelona</strong> y área metropolitana. Nuestro equipo de fontaneros autorizados cuenta con más de 8 años de experiencia resolviendo todo tipo de incidencias, desde fugas de agua y atascos hasta la instalación completa de sistemas sanitarios en viviendas y locales comerciales.
            </p>
            <p class="text-gray-600 text-base md:text-lg leading-relaxed">
              Realizamos <strong>instalaciones de agua fría y caliente</strong>, acometidas generales, montaje de calderas termoeléctricas y aerotérmicas, así como la sustitución integral de tuberías antiguas por materiales modernos de mayor durabilidad. Utilizamos técnicas de detección de fugas no invasivas para minimizar las obras en tu hogar.
            </p>
            <p class="text-gray-600 text-base md:text-lg leading-relaxed">
              Atendemos con agilidad las <strong>averías de fontanería</strong> que no pueden esperar: fugas, roturas de tuberías, problemas con la caldera o atascos. Solicita tu presupuesto gratuito y descubre por qué somos el fontanero de confianza de cientos de hogares en Barcelona.
            </p>
          </div>

          <!-- Servicios en detalle -->
          <ServiceDetail items={detalle} />

          <!-- Services + Incidencias grid -->
          <div class="grid md:grid-cols-2 gap-8 mb-14">

            <!-- Left: Nuestros Servicios -->
            <div data-animate="fade-left" class="cta-service-card bg-white p-6 md:p-8 rounded-2xl shadow-md border border-gray-100 border-l-4 border-l-primary relative overflow-hidden">
              <div class="cta-stat-shine"></div>
              <div class="relative z-[1]">
                <div class="flex items-center gap-3 mb-6">
                  <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center">
                    <Icon name="lucide:list-checks" class="w-5 h-5 text-primary" />
                  </div>
                  <h2 class="text-xl font-bold text-slate-800">Nuestros Servicios</h2>
                </div>
                <ul class="space-y-3">
                  {services.map(service => (
                    <li class="flex items-start text-gray-600 text-sm leading-snug">
                      <Icon name="lucide:circle-check" class="w-4 h-4 text-primary mr-2.5 mt-0.5 flex-shrink-0" />
                      <h3>{service.title}</h3>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <!-- Right: Incidencias -->
            <div data-animate="fade-right">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 bg-amber-50 rounded-xl flex items-center justify-center">
                  <Icon name="lucide:alert-triangle" class="w-5 h-5 text-amber-500" />
                </div>
                <h2 class="text-xl font-bold text-slate-800">Incidencias Comunes</h2>
              </div>
              <div data-stagger class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {incidencias.map(incidencia => (
                  <div data-animate="fade-up" class="cta-service-card bg-white p-5 rounded-2xl shadow-md border border-gray-100 border-l-4 border-l-amber-400 relative overflow-hidden group">
                    <div class="cta-stat-shine"></div>
                    <div class="relative z-[1]">
                      <h3 class="font-bold text-slate-800 mb-1.5 group-hover:text-primary transition-colors">{incidencia.title}</h3>
                      <p class="text-gray-600 text-sm leading-snug">{incidencia.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Benefits -->
          <div class="mb-14">
            <div class="text-center mb-8">
              <div data-animate="fade-up" class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-sm font-medium mb-4">
                <Icon name="lucide:award" class="w-4 h-4" />
                Nuestras garantías
              </div>
              <h2 data-animate="fade-up" class="text-2xl md:text-3xl font-bold">¿Por qué Elegir IS Instalaciones?</h2>
            </div>
            <div data-stagger class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-5xl mx-auto">
              {benefits.map(benefit => (
                <div data-animate="fade-up" class="cta-service-card bg-white text-center p-6 rounded-2xl shadow-md border border-gray-100 relative overflow-hidden group">
                  <div class="cta-stat-shine"></div>
                  <div class="relative z-[1]">
                    <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform duration-300">
                      <Icon name={benefit.icon} class="w-6 h-6 text-primary" />
                    </div>
                    <h3 class="font-bold text-slate-800 mb-2">{benefit.title}</h3>
                    <p class="text-sm text-gray-600 leading-snug">{benefit.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- FAQ -->
          <div class="max-w-4xl mx-auto">
            <div class="text-center mb-8">
              <div data-animate="fade-up" class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-sm font-medium mb-4">
                <Icon name="lucide:help-circle" class="w-4 h-4" />
                Resolvemos tus dudas
              </div>
              <h2 data-animate="fade-up" class="text-2xl md:text-3xl font-bold">Preguntas Frecuentes</h2>
            </div>
            <div data-stagger class="space-y-4">
              {faqItems.map(item => (
                <div data-animate="fade-up" class="cta-service-card bg-white rounded-2xl p-6 shadow-md border border-gray-100 relative overflow-hidden group">
                  <div class="cta-stat-shine"></div>
                  <div class="relative z-[1]">
                    <h3 class="text-lg font-bold text-slate-800 mb-2 group-hover:text-primary transition-colors">{item.question}</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">{item.answer}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Proceso de trabajo -->
    <ServiceProcess servicio="tu instalación de fontanería" />

    <!-- CTA -->
    <ServiceCTABanner
      title="¿Tienes una fuga o necesitas un fontanero?"
      text="Pide tu presupuesto de fontanería gratuito y sin compromiso. Fontaneros autorizados, respuesta rápida y 2 años de garantía en cada trabajo."
    />

    <ContactSection />
  </main>

</Layout>
