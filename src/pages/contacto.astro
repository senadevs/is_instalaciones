---
import Layout from '../layouts/Layout.astro';
import Header from '../components/ui/Header.astro';
import Footer from '../components/ui/Footer.astro';
import ContactSection from '../components/contact/ContactSection.astro';
import { Icon } from 'astro-icon/components';

const atentionChannels = [
  {
    icon: "lucide:phone",
    color: "text-primary",
    title: "Llámanos",
    description: "Te atendemos de lunes a sábado y resolvemos tus dudas al momento",
    action: "Llamar ahora",
    link: "tel:+34637591736"
  },
  {
    icon: "lucide:message-circle",
    color: "text-green-500",
    title: "WhatsApp",
    description: "Respuesta rápida a tus consultas por mensaje",
    action: "Chatear",
    link: "https://wa.me/34637591736"
  },
  {
    icon: "lucide:mail",
    color: "text-blue-500",
    title: "Email",
    description: "Solicita presupuesto o información detallada",
    action: "Escribir",
    link: "mailto:isinstalacionesbcn@gmail.com"
  }
];

const serviceAreas = [
  "Barcelona Ciudad",
  "Hospitalet de Llobregat",
  "Badalona",
  "Santa Coloma",
  "Sant Adrià",
  "Cornellà",
  "Esplugues",
  "Sant Just Desvern",
  "Sant Joan Despí"
];

const faqItems = [
  {
    question: "¿En cuánto tiempo respondéis a una solicitud?",
    answer: "Respondemos a tu consulta en menos de 24 horas. Para cualquier avería o duda puedes llamarnos o escribirnos por WhatsApp en nuestro horario de atención."
  },
  {
    question: "¿Ofrecen presupuestos sin compromiso?",
    answer: "Sí, realizamos visitas técnicas y elaboramos presupuestos detallados sin ningún compromiso."
  },
  {
    question: "¿Qué garantía ofrecen en sus trabajos?",
    answer: "Todos nuestros trabajos cuentan con garantía de 2 años en mano de obra y materiales."
  },
  {
    question: "¿Trabajan los fines de semana?",
    answer: "Sí, abrimos los sábados de 9:00 a 14:00 para trabajos programados. Escríbenos o llámanos y te damos cita."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<Layout
  title="Contacto - IS.INSTALACIONES"
  description="Contacta con nosotros para cualquier consulta sobre instalaciones y reformas en Barcelona. Respuesta rápida y presupuesto sin compromiso."
  additionalSchema={faqSchema}
>
  
  <main class="pt-20">
    <!-- Hero Section -->
    <section class="relative py-20 border-b border-primary/20">
      <div class="absolute inset-0 bg-black/50 z-10"></div>
      <img 
        src="https://images.pexels.com/photos/5668858/pexels-photo-5668858.jpeg"
        alt="Contacto IS.INSTALACIONES - Atención personalizada"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="container mx-auto px-4 relative z-20">
        <div class="max-w-4xl mx-auto text-center text-white">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">¿Necesitas Ayuda?</h1>
          <p class="text-lg md:text-xl mb-8">
            Estamos aquí para ayudarte con cualquier consulta o proyecto
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a 
              href="tel:+34637591736"
              class="bg-primary text-white px-8 py-3 rounded-lg hover:bg-secondary transition-colors flex items-center gap-2"
            >
              <Icon name="lucide:phone" class="w-6 h-6" />
              Llamar ahora
            </a>
            <a 
              href="https://wa.me/34637591736"
              class="bg-white text-primary px-8 py-3 rounded-lg hover:bg-gray-100 transition-colors flex items-center gap-2"
            >
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
              <span class="text-2xl"></span>
              WhatsApp
            </a>
            <a
              href="/estimador"
              data-cta="estimador_contacto"
              class="bg-primary/90 text-white px-8 py-3 rounded-lg hover:bg-primary transition-colors flex items-center gap-2 border border-white/20"
            >
              <Icon name="lucide:ruler" class="w-6 h-6" />
              Probar estimador 3D
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Zonas de Servicio -->
    <section id="zonas" class="py-16 bg-gray-50 scroll-mt-28">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <div class="text-center mb-8">
            <div data-animate="fade-up" class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-sm font-medium mb-4">
              <Icon name="lucide:map-pin" class="w-4 h-4" />
              Cobertura en Barcelona
            </div>
            <h2 data-animate="fade-up" class="text-2xl md:text-3xl font-bold">Zonas de Servicio</h2>
          </div>
          <div data-stagger class="grid grid-cols-2 sm:grid-cols-3 gap-4 max-w-4xl mx-auto">
            {serviceAreas.map(area => (
              <div data-zona={area.toLowerCase()} data-animate="fade-up" class="zona-card cta-service-card bg-white p-4 rounded-2xl shadow-md border border-gray-100 text-center relative overflow-hidden group transition-all duration-300">
                <div class="cta-stat-shine"></div>
                <div class="relative z-[1] flex items-center justify-center gap-2">
                  <Icon name="lucide:map-pin" class="w-4 h-4 text-primary flex-shrink-0" />
                  <span class="font-medium text-slate-800 text-sm">{area}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Preguntas Frecuentes -->
    <section id="faq" class="py-16 bg-gray-50 scroll-mt-28">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-8">
            <div data-animate="fade-up" class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-sm font-medium mb-4">
              <Icon name="lucide:help-circle" class="w-4 h-4" />
              Resolvemos tus dudas
            </div>
            <h2 data-animate="fade-up" class="text-2xl md:text-3xl font-bold">Preguntas Frecuentes</h2>
          </div>
          <div data-stagger class="space-y-4">
            {faqItems.map(item => (
              <div data-animate="fade-up" class="cta-service-card bg-white rounded-2xl p-6 shadow-md border border-gray-100 relative overflow-hidden group">
                <div class="cta-stat-shine"></div>
                <div class="relative z-[1]">
                  <h3 class="text-lg font-bold text-slate-800 mb-2 group-hover:text-primary transition-colors">{item.question}</h3>
                  <p class="text-gray-600 text-sm leading-relaxed">{item.answer}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="py-12 border-y border-primary/10 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto rounded-[2rem] bg-primary text-white p-8 md:p-10 shadow-xl">
          <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
            <div class="max-w-2xl">
              <p class="text-sm font-semibold uppercase tracking-[0.22em] text-white/70">Plano previo</p>
              <h2 class="mt-2 text-2xl md:text-3xl font-bold">Define la base de tu reforma antes de hablar con nosotros</h2>
              <p class="mt-3 text-white/85 leading-relaxed">
                Si ya tienes clara la distribución, entra al estimador 3D, prepara la planta y exporta el plano para que la primera conversación vaya al detalle.
              </p>
            </div>
            <a
              href="/estimador"
              data-cta="estimador_contacto_banner"
              class="inline-flex items-center justify-center gap-2 rounded-xl bg-white px-6 py-3 text-sm font-bold text-primary hover:bg-slate-100 transition-colors"
            >
              <Icon name="lucide:layout-grid" class="w-5 h-5" />
              Abrir estimador
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Formulario de Contacto -->
    <ContactSection />
  </main>

</Layout>
