---
import { Icon } from 'astro-icon/components';

const projects = [
  {
    image: "/electricista.webp",
    title: "Reforma Eléctrica Integral",
    description: "Renovación completa del sistema eléctrico en vivienda de 120m² en el Eixample, Barcelona.",
    tags: ["Electricidad", "Reformas"],
    cta: "Solicita Presupuesto",
    link: "/contacto"
  },
  {
    image: "https://images.pexels.com/photos/6419128/pexels-photo-6419128.jpeg?auto=compress&cs=tinysrgb&w=1920&h=1080",
    title: "Instalación de Climatización",
    description: "Sistema de aire acondicionado por conductos para oficina corporativa en Sant Cugat.",
    tags: ["Climatización", "Comercial"],
    cta: "Pide tu Presupuesto",
    link: "/contacto"
  },
  {
    image: "https://images.pexels.com/photos/6816567/pexels-photo-6816567.jpeg?auto=compress&cs=tinysrgb&w=1920&h=1080",
    title: "Fontanería y Saneamiento",
    description: "Sustitución integral de tuberías y nueva instalación sanitaria en edificio residencial.",
    tags: ["Fontanería", "Residencial"],
    cta: "Consulta Gratuita",
    link: "/contacto"
  },
  {
    image: "https://images.pexels.com/photos/8961438/pexels-photo-8961438.jpeg?auto=compress&cs=tinysrgb&w=1920&h=1080",
    title: "Reforma Integral Vivienda",
    description: "Proyecto completo de reforma incluyendo electricidad, fontanería y acabados en Gràcia.",
    tags: ["Reformas", "Integral"],
    cta: "Hablemos de tu Proyecto",
    link: "/contacto"
  }
];
---

<section class="relative border-b border-primary/20 overflow-hidden">
  <div class="glitch-slider swiper w-full">
    <div class="swiper-wrapper">
      {projects.map((project) => (
        <div class="swiper-slide">
          <div class="relative w-full h-[60vh] md:h-[70vh] group overflow-hidden">
            <img
              src={project.image}
              alt={project.title}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <!-- Overlay gradiente -->
            <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/50 to-transparent"></div>
            <!-- Crack overlay -->
            <div class="glitch-crack-overlay absolute inset-0 pointer-events-none opacity-0"></div>
            <!-- Contenido CTA -->
            <div class="absolute inset-0 flex items-center z-10">
              <div class="container mx-auto px-6 md:px-12 lg:px-20">
                <div class="max-w-2xl text-white">
                  <div class="flex flex-wrap gap-2 mb-4">
                    {project.tags.map((tag) => (
                      <span class="px-3 py-1 text-xs font-semibold uppercase tracking-wider bg-white/10 backdrop-blur-sm rounded-full border border-white/20">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <h3 class="text-3xl md:text-4xl lg:text-5xl font-extrabold mb-4 leading-tight">{project.title}</h3>
                  <p class="text-base md:text-lg text-gray-200 mb-8 max-w-lg leading-relaxed">{project.description}</p>
                  <div class="flex flex-wrap gap-4">
                    <a
                      href={project.link}
                      class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 md:px-8 md:py-4 rounded-lg font-bold hover:bg-secondary transition-all shadow-lg hover:shadow-xl text-sm md:text-base"
                    >
                      <Icon name="lucide:send" class="w-5 h-5" />
                      {project.cta}
                    </a>
                    <a
                      href="tel:+34637591736"
                      class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm text-white px-6 py-3 md:px-8 md:py-4 rounded-lg font-bold border border-white/20 hover:bg-white/20 transition-all text-sm md:text-base"
                    >
                      <Icon name="lucide:phone" class="w-5 h-5" />
                      Llamar Ahora
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Pagination bar -->
    <div class="glitch-pagination absolute bottom-0 left-0 right-0 z-20"></div>

    <!-- Navigation -->
    <button class="glitch-prev absolute left-3 md:left-6 top-1/2 -translate-y-1/2 z-20 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center bg-black/40 backdrop-blur-sm rounded-full border border-white/20 text-white hover:bg-primary/80 transition-all" aria-label="Anterior">
      <Icon name="lucide:chevron-left" class="w-5 h-5 md:w-6 md:h-6" />
    </button>
    <button class="glitch-next absolute right-3 md:right-6 top-1/2 -translate-y-1/2 z-20 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center bg-black/40 backdrop-blur-sm rounded-full border border-white/20 text-white hover:bg-primary/80 transition-all" aria-label="Siguiente">
      <Icon name="lucide:chevron-right" class="w-5 h-5 md:w-6 md:h-6" />
    </button>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Navigation, Pagination, Autoplay, EffectCreative } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/effect-creative";

  function initGlitchSlider() {
    const el = document.querySelector(".glitch-slider");
    if (!el) return;

    new Swiper(".glitch-slider", {
      modules: [Navigation, Pagination, Autoplay, EffectCreative],
      effect: "creative",
      creativeEffect: {
        prev: {
          shadow: false,
          translate: ["-20%", 0, -1],
          opacity: 0
        },
        next: {
          translate: ["100%", 0, 0],
          opacity: 1
        }
      },
      speed: 800,
      loop: true,
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
        pauseOnMouseEnter: true
      },
      navigation: {
        nextEl: ".glitch-next",
        prevEl: ".glitch-prev"
      },
      pagination: {
        el: ".glitch-pagination",
        clickable: true,
        type: "progressbar"
      },
      on: {
        slideChangeTransitionStart: function () {
          const activeSlide = this.slides[this.activeIndex];
          if (activeSlide) {
            activeSlide.classList.add("glitch-active");
            const crack = activeSlide.querySelector(".glitch-crack-overlay");
            if (crack) {
              crack.classList.add("crack-visible");
              setTimeout(() => crack.classList.remove("crack-visible"), 600);
            }
          }
        },
        slideChangeTransitionEnd: function () {
          this.slides.forEach((slide: Element) => slide.classList.remove("glitch-active"));
        }
      }
    });
  }

  // Initialize on multiple events to ensure it works
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initGlitchSlider);
  } else {
    initGlitchSlider();
  }
  document.addEventListener("astro:page-load", initGlitchSlider);
</script>
