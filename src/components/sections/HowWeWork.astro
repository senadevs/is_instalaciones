---
import { Icon } from 'astro-icon/components';

const steps = [
  {
    number: "01",
    icon: "lucide:phone-call",
    color: "text-green-500",
    borderColor: "border-green-500/30",
    bgNumber: "bg-green-500",
    title: "Contacto",
    description: "Llámanos, escríbenos por WhatsApp o rellena el formulario. Respondemos en menos de 24 horas."
  },
  {
    number: "02",
    icon: "lucide:search",
    color: "text-blue-500",
    borderColor: "border-blue-500/30",
    bgNumber: "bg-blue-500",
    title: "Diagnóstico",
    description: "Visita técnica gratuita para evaluar tu proyecto y presupuesto sin compromiso."
  },
  {
    number: "03",
    icon: "lucide:hard-hat",
    color: "text-amber-500",
    borderColor: "border-amber-500/30",
    bgNumber: "bg-amber-500",
    title: "Ejecución",
    description: "Técnicos autorizados, materiales de primera calidad y cumplimiento de plazos."
  },
  {
    number: "04",
    icon: "lucide:shield-check",
    color: "text-primary",
    borderColor: "border-primary/30",
    bgNumber: "bg-primary",
    title: "Garantía",
    description: "2 años de garantía en mano de obra y materiales en todos nuestros trabajos."
  }
];
---

<section class="py-16 md:py-20 border-b border-primary/20">
  <div class="container mx-auto px-4">
    <div class="max-w-5xl mx-auto">
      <h2 data-animate="fade-up" class="text-3xl md:text-4xl font-bold text-center mb-4">Cómo Trabajamos</h2>
      <p data-animate="fade-up" data-delay="200" class="text-lg text-gray-600 text-center mb-12 max-w-2xl mx-auto">
        Un proceso claro y transparente para que tu proyecto sea un éxito desde el primer contacto
      </p>

      <!-- Desktop: Zigzag timeline -->
      <div class="hidden md:block relative">
        <!-- Vertical center line (dashed blueprint style) -->
        <div class="absolute left-1/2 top-0 bottom-0 w-0.5 -translate-x-1/2 hww-timeline-line"></div>

        {steps.map((step, i) => (
          <div class="relative flex items-center mb-16 last:mb-0" data-animate={i % 2 === 0 ? "fade-right" : "fade-left"}>
            {/* Left side content (even steps) */}
            <div class={`w-5/12 ${i % 2 === 0 ? 'pr-8 text-right' : 'pr-8 text-right opacity-0 pointer-events-none'}`}>
              {i % 2 === 0 && (
                <div class={`hww-card bg-white p-6 rounded-lg shadow-md border ${step.borderColor} inline-block text-left relative`}>
                  <div class="flex items-center gap-3 mb-3">
                    <Icon name={step.icon} class={`w-8 h-8 ${step.color}`} />
                    <h3 class="text-xl font-bold">{step.title}</h3>
                  </div>
                  <p class="text-gray-600">{step.description}</p>
                  {/* Connector line from card to circle */}
                  <div class="hww-connector hww-connector-right"></div>
                </div>
              )}
            </div>

            {/* Center number circle */}
            <div class="w-2/12 flex justify-center relative z-10">
              <div class={`hww-circle w-14 h-14 ${step.bgNumber} text-white rounded-full flex items-center justify-center font-bold text-lg shadow-lg ring-4 ring-white`}>
                {step.number}
              </div>
            </div>

            {/* Right side content (odd steps) */}
            <div class={`w-5/12 ${i % 2 !== 0 ? 'pl-8' : 'pl-8 opacity-0 pointer-events-none'}`}>
              {i % 2 !== 0 && (
                <div class={`hww-card bg-white p-6 rounded-lg shadow-md border ${step.borderColor} inline-block text-left relative`}>
                  <div class="flex items-center gap-3 mb-3">
                    <Icon name={step.icon} class={`w-8 h-8 ${step.color}`} />
                    <h3 class="text-xl font-bold">{step.title}</h3>
                  </div>
                  <p class="text-gray-600">{step.description}</p>
                  {/* Connector line from card to circle */}
                  <div class="hww-connector hww-connector-left"></div>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- Mobile: Simple vertical stack with line -->
      <div class="md:hidden relative">
        <!-- Vertical line mobile -->
        <div class="absolute left-6 top-0 bottom-0 w-0.5 hww-timeline-line"></div>

        <div data-stagger class="space-y-6">
          {steps.map((step) => (
            <div data-animate="fade-up" class={`bg-white p-6 rounded-lg shadow-md border ${step.borderColor} flex gap-4 relative ml-3`}>
              <div class={`w-12 h-12 ${step.bgNumber} text-white rounded-full flex items-center justify-center font-bold text-lg shrink-0 relative z-10 ring-4 ring-white`}>
                {step.number}
              </div>
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <Icon name={step.icon} class={`w-6 h-6 ${step.color}`} />
                  <h3 class="text-lg font-bold">{step.title}</h3>
                </div>
                <p class="text-gray-600 text-sm">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div data-animate="fade-up" class="text-center mt-12">
        <a
          href="#contacto"
          class="inline-flex items-center gap-2 bg-primary text-white px-8 py-3 rounded-lg font-medium hover:bg-secondary transition-colors shadow-md hover:shadow-lg"
        >
          <Icon name="lucide:rocket" class="w-5 h-5" />
          Empieza tu Proyecto
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* Blueprint-style dashed timeline line */
  .hww-timeline-line {
    background: repeating-linear-gradient(
      to bottom,
      var(--color-primary) 0px,
      var(--color-primary) 8px,
      transparent 8px,
      transparent 16px
    );
    opacity: 0.3;
  }

  :global([data-theme="dark"]) .hww-timeline-line {
    background: repeating-linear-gradient(
      to bottom,
      #fff 0px,
      #fff 8px,
      transparent 8px,
      transparent 16px
    );
    opacity: 0.35;
  }

  /* Animated drawing effect on the timeline */
  .hww-timeline-line {
    background-size: 100% 200%;
    animation: hww-draw-line 2s ease-out forwards;
  }

  @keyframes hww-draw-line {
    from { clip-path: inset(0 0 100% 0); }
    to { clip-path: inset(0 0 0% 0); }
  }

  /* Connector lines from cards to circles */
  .hww-connector {
    position: absolute;
    top: 50%;
    height: 2px;
    width: 0;
    background: repeating-linear-gradient(
      to right,
      var(--color-primary) 0px,
      var(--color-primary) 6px,
      transparent 6px,
      transparent 12px
    );
    opacity: 0.4;
    transition: width 0.5s ease-out 0.3s, opacity 0.3s ease;
  }

  :global([data-theme="dark"]) .hww-connector {
    background: repeating-linear-gradient(
      to right,
      #fff 0px,
      #fff 6px,
      transparent 6px,
      transparent 12px
    );
    opacity: 0.5;
  }

  /* Animate connectors when visible */
  .is-visible .hww-connector {
    width: 32px;
  }

  .hww-connector-right {
    right: -40px;
    transform: translateY(-50%);
  }

  .hww-connector-left {
    left: -40px;
    transform: translateY(-50%);
  }

  /* Pulse on circle when card is visible */
  .is-visible .hww-circle {
    animation: hww-pulse 0.6s ease-out;
  }

  @keyframes hww-pulse {
    0% { box-shadow: 0 0 0 0 rgba(4, 106, 83, 0.4); }
    70% { box-shadow: 0 0 0 12px rgba(4, 106, 83, 0); }
    100% { box-shadow: 0 0 0 0 rgba(4, 106, 83, 0); }
  }

  /* Hover effect on cards - draw connector solid */
  .hww-card:hover .hww-connector {
    opacity: 0.8;
    background: linear-gradient(
      to right,
      var(--color-primary),
      var(--color-primary)
    );
    transition: opacity 0.3s ease, background 0.3s ease;
  }

  :global([data-theme="dark"]) .hww-card:hover .hww-connector {
    background: linear-gradient(to right, #fff, #fff);
  }

  .hww-card:hover {
    transform: translateY(-2px);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .is-visible .hww-circle {
      animation: none;
    }
    .hww-card:hover {
      transform: none;
    }
    .hww-timeline-line {
      animation: none;
      clip-path: none;
    }
    .hww-connector {
      width: 32px;
      transition: none;
    }
  }
</style>
