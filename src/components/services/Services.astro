---
import { Icon } from "astro-icon/components";

const services = [
  {
    title: "Electricidad",
    description: "Instalaciones y reparaciones eléctricas profesionales.",
    icon: "lucide:zap",
    color: "text-amber-500",
    href: "/servicios/electricidad",
  },
  {
    title: "Fontanería",
    description: "Instalaciones y reparaciones de fontanería profesionales.",
    icon: "lucide:droplets",
    color: "text-blue-500",
    href: "/servicios/fontaneria",
  },
  {
    title: "Climatización",
    description: "Servicios de climatización profesionales.",
    icon: "lucide:snowflake",
    color: "text-cyan-500",
    href: "/servicios/climatizacion",
  },
  {
    title: "Reformas Generales",
    description: "Instalaciones y reparaciones de gas profesionales.",
    icon: "lucide:wrench",
    color: "text-orange-500",
    href: "/servicios/reformas",
  },
];
---

<section
  id="servicios"
  aria-label="Servicios"
  class="py-16 md:py-20 bg-white border-b border-primary/20 hover:border-primary/30 transition-colors"
>
  <div class="container mx-auto px-4">
    <h2
      class="text-3xl md:text-4xl lg:text-5xl font-bold text-center mb-4 hover:text-primary transition-colors"
    >
      Nuestros Servicios
    </h2>
    <p class="text-center text-gray-600 mb-12 text-base md:text-lg">
      Soluciones profesionales para todas tus necesidades.
    </p>

    <div
      class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 max-w-7xl mx-auto"
      data-stagger
    >
      {
        services.map((service, index) => (
          <a
            href={service.href}
            class="bg-white dark:bg-slate-900 p-8 rounded-2xl shadow-md border border-primary/10 hover:border-primary/30 transition-all hover:shadow-xl group relative overflow-hidden"
            data-animate="fade-up"
          >
            <div class="relative mb-6">
              <Icon
                name={service.icon}
                class={`w-12 h-12 transition-all duration-300 group-hover:scale-110 ${service.color}`}
              />

              {/* Custom Animation: Air Conditioning */}
              {service.title === "Climatización" && (
                <div class="absolute -bottom-8 left-0 w-16 flex justify-around opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                  <div
                    class="air-line-giant w-1.5 h-12 bg-cyan-200/50 rounded-full opacity-60"
                    style="animation-delay: 0s"
                  />
                  <div
                    class="air-line-giant w-1.5 h-16 bg-cyan-200/50 rounded-full opacity-60"
                    style="animation-delay: 0.2s"
                  />
                  <div
                    class="air-line-giant w-1.5 h-12 bg-cyan-200/50 rounded-full opacity-60"
                    style="animation-delay: 0.4s"
                  />
                </div>
              )}

              {/* Custom Animation: Leaking Pipe */}
              {service.title === "Fontanería" && (
                <div class="absolute top-10 left-8 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                  <div class="water-drop-giant w-4 h-6 bg-blue-400 rounded-full" />
                </div>
              )}
            </div>

            <h3
              aria-label={service.title}
              class="text-xl font-bold mb-3 group-hover:text-primary transition-colors flex items-center gap-2"
            >
              {service.title}
              <Icon
                name="lucide:chevron-right"
                class="w-4 h-4 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all"
              />
            </h3>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
              {service.description}
            </p>

            {/* Background design element */}
            <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-primary/5 rounded-full group-hover:scale-150 transition-transform duration-500" />
          </a>
        ))
      }
    </div>
  </div>
</section>
