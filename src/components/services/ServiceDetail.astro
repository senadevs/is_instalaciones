---
import { Icon } from 'astro-icon/components';

interface DetailItem {
  title: string;
  image: string;
  text: string;
  bullets: string[];
}
interface Props {
  items: DetailItem[];
}
const { items } = Astro.props;
---

<div class="space-y-10 md:space-y-16 my-14">
  {items.map((item, i) => (
    <div class={`flex flex-col gap-6 md:gap-10 items-center ${i % 2 === 1 ? 'md:flex-row-reverse' : 'md:flex-row'}`}>
      <div data-animate={i % 2 === 1 ? 'fade-left' : 'fade-right'} class="w-full md:w-1/2">
        <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-100 aspect-[4/3]">
          <img src={item.image} alt={item.title} loading="lazy" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
        </div>
      </div>
      <div data-animate={i % 2 === 1 ? 'fade-right' : 'fade-left'} class="w-full md:w-1/2">
        <h2 class="text-2xl font-bold text-slate-800 mb-3">{item.title}</h2>
        <p class="text-gray-600 leading-relaxed mb-4">{item.text}</p>
        <ul class="grid sm:grid-cols-2 gap-2">
          {item.bullets.map(b => (
            <li class="flex items-start text-sm text-gray-700">
              <Icon name="lucide:circle-check" class="w-4 h-4 text-primary mr-2 mt-0.5 flex-shrink-0" />
              {b}
            </li>
          ))}
        </ul>
      </div>
    </div>
  ))}
</div>
