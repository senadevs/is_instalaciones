---
import { Icon } from 'astro-icon/components';
import { immersiveContent } from '../../data/immersiveContent';
---

<div id="chat-widget" class="fixed bottom-6 right-6 z-[70]">
  <div
    id="chat-window"
    class="fixed md:absolute inset-0 md:inset-auto md:bottom-20 md:right-0 w-full md:w-[380px] md:max-w-[calc(100vw-2rem)] bg-white md:rounded-3xl shadow-2xl md:border md:border-gray-200 overflow-hidden z-[60]"
    style="display:none;"
  >
    <div class="bg-primary p-4 flex items-center justify-between gap-3 shrink-0">
      <div class="flex items-center gap-3 min-w-0">
        <img src="/isbot.png" alt="IS Bot" class="w-11 h-11 object-contain shrink-0" width="44" height="44" />
        <div class="min-w-0">
          <p class="text-white font-semibold text-sm leading-tight truncate">IS Instalaciones</p>
          <div class="flex items-center gap-1.5">
            <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
            <span class="text-white/70 text-xs">En línea</span>
          </div>
        </div>
      </div>

      <button
        id="imm-toggle"
        class="hidden md:inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/10 px-3 py-2 text-white/90 hover:text-white hover:bg-white/15 transition-colors"
        type="button"
        aria-pressed="false"
        aria-label="Activar modo inmersivo"
      >
        <span class="relative flex h-3.5 w-3.5 items-center justify-center">
          <span class="absolute inline-flex h-full w-full rounded-full bg-white/40 opacity-75 animate-ping"></span>
          <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-white"></span>
        </span>
        <span class="text-xs font-semibold tracking-wide">Inmersivo</span>
      </button>

      <button id="chat-close" class="text-white/70 hover:text-white transition-colors p-1" aria-label="Cerrar chat" type="button">
        <Icon name="lucide:x" class="w-5 h-5" />
      </button>
    </div>

    <div id="chat-messages" class="flex-1 md:h-[460px] md:flex-none overflow-y-auto p-4 space-y-3 bg-gray-50">
      <div class="flex gap-2">
        <img src="/isbot.png" alt="IS Bot" class="w-10 h-10 object-contain shrink-0" width="40" height="40" />
        <div class="bg-white p-3 rounded-2xl rounded-tl-sm shadow-sm border border-gray-100 max-w-[84%]">
          <p class="text-sm text-gray-700">
            Hola, soy el asistente de <strong>IS Instalaciones</strong>. ¿En qué puedo ayudarte?
          </p>
        </div>
      </div>

      <div id="chat-quick-replies" class="flex flex-wrap gap-2 pl-10">
        <button class="chat-quick-reply text-xs bg-primary text-white px-3 py-1.5 rounded-full hover:bg-secondary transition-colors">Qué servicios ofrecéis</button>
        <button class="chat-quick-reply text-xs bg-primary text-white px-3 py-1.5 rounded-full hover:bg-secondary transition-colors">Zonas de cobertura</button>
        <button class="chat-quick-reply text-xs bg-primary text-white px-3 py-1.5 rounded-full hover:bg-secondary transition-colors">Horario de atención</button>
      </div>
    </div>

    <div class="p-3 border-t border-gray-200 bg-white shrink-0">
      <form id="chat-form" class="flex items-center gap-2">
        <input
          id="chat-input"
          type="text"
          placeholder="Escribe tu mensaje..."
          class="flex-1 px-4 py-2.5 rounded-xl border border-gray-200 bg-gray-50 text-sm focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
          autocomplete="off"
        />
        <button type="submit" class="w-10 h-10 bg-primary text-white rounded-xl flex items-center justify-center hover:bg-secondary transition-colors shrink-0" aria-label="Enviar mensaje">
          <Icon name="lucide:send" class="w-4 h-4" />
        </button>
      </form>
    </div>
  </div>

  <div
    id="chat-teaser"
    class="absolute bottom-20 right-0 w-64 bg-white rounded-2xl rounded-br-sm shadow-xl border border-gray-100 p-3.5 pr-8 hidden"
  >
    <button id="chat-teaser-close" class="absolute top-2 right-2 text-gray-400 hover:text-gray-600" aria-label="Cerrar" type="button">
      <Icon name="lucide:x" class="w-3.5 h-3.5" />
    </button>
    <div class="flex items-start gap-2.5">
      <img src="/isbot.png" alt="IS Bot" class="w-9 h-9 object-contain shrink-0" width="36" height="36" />
      <p id="chat-teaser-text" class="text-sm text-gray-700 leading-snug">¡Hola! ¿Te ayudo a encontrar lo que buscas?</p>
    </div>
  </div>

  <form
    id="immersive-chat-form"
    class="fixed bottom-4 left-1/2 z-[75] hidden w-[min(720px,calc(100vw-0.5rem))] -translate-x-1/2"
    aria-label="Chat inmersivo"
  >
    <div class="flex items-center gap-2 rounded-full border border-white/70 bg-white/88 p-2 shadow-[0_18px_45px_rgba(15,23,42,.18)] backdrop-blur-xl">
      <div class="flex items-center gap-2 pl-2 pr-1 text-slate-700">
        <img src="/isbot.png" alt="IS Bot" class="w-8 h-8 object-contain" width="32" height="32" />
        <span class="text-xs font-semibold tracking-[0.18em] uppercase text-emerald-700">IA</span>
      </div>
      <input
        id="immersive-chat-input"
        type="text"
        placeholder="Pregunta al agente..."
        class="flex-1 rounded-full border border-transparent bg-transparent px-3 py-2 text-sm text-slate-700 outline-none placeholder:text-slate-400 focus:border-emerald-200 focus:bg-white"
        autocomplete="off"
      />
      <button
        type="submit"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-r from-emerald-500 to-emerald-600 text-white shadow-md hover:shadow-lg transition-all"
        aria-label="Enviar mensaje inmersivo"
      >
        <Icon name="lucide:send" class="w-4 h-4" />
      </button>
    </div>
  </form>

  <button
    id="chat-toggle"
    class="chat-bubble-btn w-16 h-16 bg-white rounded-full shadow-lg hover:shadow-xl flex items-center justify-center hover:scale-110 transition-all duration-300 relative border-2 border-primary/20"
    aria-label="Abrir chat"
    type="button"
  >
    <img src="/isbot.png" alt="Chat" id="chat-icon-open" class="w-14 h-14 object-contain" width="56" height="56" />
    <Icon name="lucide:x" id="chat-icon-close" class="w-7 h-7 text-primary hidden" />
    <span id="chat-notification" class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 rounded-full border-2 border-white animate-pulse"></span>
  </button>

  <div id="isbot-immersive-stage" class="fixed inset-0 z-[55] hidden overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(4,106,83,.22),transparent_35%),radial-gradient(circle_at_top_right,rgba(21,96,81,.16),transparent_25%),linear-gradient(135deg,var(--color-background),rgba(4,106,83,.08))]"></div>
    <div class="absolute inset-0 bg-grid opacity-[0.16]"></div>
    <div class="absolute -left-24 top-16 h-64 w-64 rounded-full bg-primary/15 blur-3xl"></div>
    <div class="absolute -right-24 bottom-24 h-80 w-80 rounded-full bg-cyan-400/15 blur-3xl"></div>

    <div class="relative z-[1] flex h-full min-h-0 flex-col">
      <div class="flex items-center justify-between gap-3 px-4 py-4 md:px-6 md:py-5">
        <div class="flex items-center gap-3 rounded-full border border-white/50 bg-white/70 backdrop-blur-xl px-4 py-2 shadow-lg">
          <img src="/isbot.png" alt="IS Bot" class="w-8 h-8 object-contain" width="32" height="32" />
          <div>
            <p class="text-sm font-semibold text-slate-900 leading-tight">Modo inmersivo activo</p>
            <p class="text-xs text-slate-500">Canvas creativo a la izquierda · agente a la derecha</p>
          </div>
        </div>

        <button
          id="immersive-exit"
          type="button"
          class="inline-flex items-center gap-2 rounded-full bg-slate-900/90 px-4 py-2 text-white shadow-xl hover:bg-slate-800 transition-colors"
          aria-label="Salir del modo inmersivo"
        >
          <Icon name="lucide:chevrons-left" class="w-4 h-4" />
          <span class="text-sm font-semibold">Salir</span>
        </button>
      </div>

      <div class="flex-1 min-h-0 px-4 pb-4 md:px-6 md:pb-6">
        <div class="grid h-full min-h-0 gap-4 lg:grid-cols-[minmax(0,1fr)_22rem]">
          <section class="min-h-0 overflow-y-auto rounded-[2.25rem] border border-white/70 bg-white/82 p-4 shadow-[0_24px_80px_rgba(15,23,42,.14)] backdrop-blur-2xl md:p-6 lg:p-8">
            <div id="immersive-content" class="min-h-full"></div>
          </section>
          <aside class="min-h-0 overflow-y-auto rounded-[2.25rem] border border-white/70 bg-white/72 p-4 text-slate-900 shadow-[0_24px_80px_rgba(15,23,42,.14)] backdrop-blur-2xl md:p-6">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-700/80">Respuesta del agente</p>
                <h3 class="mt-3 text-2xl font-black tracking-tight text-slate-900">Narrativa visual</h3>
              </div>
              <div class="flex h-11 w-11 items-center justify-center rounded-full bg-emerald-500/10 text-emerald-700">
                <Icon name="lucide:sparkles" class="h-5 w-5" />
              </div>
            </div>
            <div id="immersive-story" class="mt-5 space-y-4"></div>
          </aside>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ immersiveContent }}>
  (function () {
    function initChat() {
      var toggle = document.getElementById('chat-toggle');
      var chatWindow = document.getElementById('chat-window');
      var closeBtn = document.getElementById('chat-close');
      var form = document.getElementById('chat-form');
      var input = document.getElementById('chat-input');
      var messagesEl = document.getElementById('chat-messages');
      var iconOpen = document.getElementById('chat-icon-open');
      var iconClose = document.getElementById('chat-icon-close');
      var notification = document.getElementById('chat-notification');
      var quickReplies = document.querySelectorAll('.chat-quick-reply');
      var immersiveToggle = document.getElementById('imm-toggle');
      var immersiveStage = document.getElementById('isbot-immersive-stage');
      var immersiveClose = document.getElementById('immersive-exit');
      var immersiveTools = document.getElementById('immersive-tools');
      var immersiveForm = document.getElementById('immersive-chat-form');
      var immersiveInput = document.getElementById('immersive-chat-input');
      var submitBtn = form ? form.querySelector('button[type="submit"]') : null;

      if (!toggle || !chatWindow || !form || !input || !messagesEl) return;
      if (toggle.dataset.chatInit === 'true') return;
      toggle.dataset.chatInit = 'true';

      var STORAGE_KEY = 'isbot-chat';
      var TOOLBAR_ACTIONS = immersiveContent.tools || [
        { action: 'services', label: 'Servicios', icon: 'layout-grid' },
        { action: 'service:electricidad', label: 'Electricidad', icon: 'zap' },
        { action: 'service:climatizacion', label: 'Climatización', icon: 'snowflake' },
        { action: 'gallery:reformas', label: 'Trabajos', icon: 'image' },
        { action: 'contact', label: 'Contacto', icon: 'phone' },
        { action: 'coverage', label: 'Cobertura', icon: 'map-pinned' },
        { action: 'emergency', label: 'Urgente', icon: 'alert-triangle' }
      ];

      var isOpen = false;
      var isStreaming = false;
      var isImmersive = false;
      var chatHistory = [];
      var lastImmersiveNarration = '';

      function saveState() {
        try {
          sessionStorage.setItem(STORAGE_KEY, JSON.stringify({ open: isOpen, history: chatHistory, immersive: isImmersive }));
        } catch (e) {}
      }

      function readState() {
        try {
          var raw = sessionStorage.getItem(STORAGE_KEY);
          if (!raw) return null;
          return JSON.parse(raw);
        } catch (e) {
          return null;
        }
      }

      function extractNavigation(text) {
        var match = text.match(/\[\[GOTO:\s*([^\]]+)\]\]/i);
        if (!match) return { clean: text, route: null };
        return {
          clean: text.replace(/\[\[GOTO:[^\]]+\]\]/ig, '').trim(),
          route: match[1].trim()
        };
      }

      function extractShow(text) {
        var match = text.match(/\[\[SHOW:\s*([^\]]+)\]\]/i);
        if (!match) return { kind: null, target: null, params: {}, raw: null };

        var raw = match[1].trim();
        var parts = raw.split('|').map(function (part) { return part.trim(); }).filter(Boolean);
        var head = parts.shift() || 'scene';
        var headParts = head.split(':');
        var kind = (headParts[0] || 'scene').trim();
        var target = (headParts[1] || '').trim();
        var params = {};

        parts.forEach(function (part) {
          var idx = part.indexOf('=');
          if (idx === -1) {
            params[part] = true;
            return;
          }
          var key = part.slice(0, idx).trim();
          var value = part.slice(idx + 1).trim();
          params[key] = value;
        });

        return { raw: raw, kind: kind, target: target, params: params };
      }

      function scrollToBottom() {
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            messagesEl.scrollTop = messagesEl.scrollHeight;
          });
        });
      }

      function isDesktopImmersiveAllowed() {
        return window.matchMedia('(min-width: 768px)').matches;
      }

      function getService(id) {
        return immersiveContent.servicePacks && immersiveContent.servicePacks[id] ? immersiveContent.servicePacks[id] : null;
      }

      function actionFromRoute(route) {
        var path = route;
        var hash = '';
        if (route.indexOf('#') >= 0) {
          var parts = route.split('#');
          path = parts[0];
          hash = parts[1] || '';
        }
        if (path === '/contacto' && hash === 'zonas') return 'coverage';
        if (path === '/contacto' || route === '/#contacto') return 'contact';
        if (path === '/servicios') return 'services';
        if (path === '/servicios/instalaciones-electricas') return 'service:electricidad';
        if (path === '/servicios/fontaneria-y-saneamiento') return 'service:fontaneria';
        if (path === '/servicios/climatizacion-y-calefaccion') return 'service:climatizacion';
        if (path === '/servicios/reformas-integrales') return 'service:reformas';
        return 'welcome';
      }

      function ensureNavStyles() {
        if (document.getElementById('isbot-anim')) return;
        var st = document.createElement('style');
        st.id = 'isbot-anim';
        st.textContent =
          '@keyframes isbot-spin{to{transform:rotate(360deg)}}' +
          '.isbot-focus{box-shadow:0 0 0 3px rgba(29,78,216,.55),0 0 26px rgba(29,78,216,.35)!important;border-radius:14px;transition:box-shadow .4s ease;scroll-margin-top:7rem;}' +
          '.isbot-zona{box-shadow:0 0 0 3px rgba(29,78,216,.7)!important;transform:scale(1.03);z-index:2;}';
        document.head.appendChild(st);
      }

      function showNavOverlay(label) {
        ensureNavStyles();
        var accent = '#1d4ed8';
        try {
          var header = document.querySelector('header');
          if (header) {
            var color = getComputedStyle(header).backgroundColor;
            if (color && color !== 'rgba(0, 0, 0, 0)') accent = color;
          }
        } catch (e) {}
        var overlay = document.createElement('div');
        overlay.id = 'isbot-nav-overlay';
        overlay.style.cssText = 'position:fixed;inset:0;z-index:54;display:flex;align-items:center;justify-content:center;background:rgba(15,23,42,.42);backdrop-filter:blur(5px);-webkit-backdrop-filter:blur(5px);opacity:0;transition:opacity .25s ease;';
        overlay.innerHTML = '<div style="background:#fff;padding:20px 24px;border-radius:20px;box-shadow:0 16px 50px rgba(0,0,0,.25);display:flex;flex-direction:column;align-items:center;gap:12px;max-width:260px;text-align:center;">'
          + '<div style="width:38px;height:38px;border:3px solid #e5e7eb;border-top-color:' + accent + ';border-radius:999px;animation:isbot-spin .8s linear infinite;"></div>'
          + '<p style="font-size:13px;color:#374151;margin:0;font-weight:500;">Te llevo a <b>' + label + '</b>...</p></div>';
        (document.getElementById('chat-widget') || document.body).appendChild(overlay);
        requestAnimationFrame(function () { overlay.style.opacity = '1'; });
      }

      function showChatNav(label) {
        ensureNavStyles();
        removeChatNav();
        var div = document.createElement('div');
        div.id = 'chat-nav-indicator';
        div.className = 'flex gap-2';
        div.innerHTML = '<img src="/isbot.png" alt="Bot" class="w-10 h-10 object-contain shrink-0" width="40" height="40" />'
          + '<div class="bg-primary/10 text-primary p-3 rounded-2xl rounded-tl-sm border border-primary/20 max-w-[85%] flex items-center gap-2">'
          + '<span style="width:14px;height:14px;border:2px solid currentColor;border-top-color:transparent;border-radius:50%;display:inline-block;animation:isbot-spin .8s linear infinite;"></span>'
          + '<span class="text-sm font-medium">Te llevo a ' + label + '...</span></div>';
        messagesEl.appendChild(div);
        scrollToBottom();
      }

      function removeChatNav() {
        var el = document.getElementById('chat-nav-indicator');
        if (el) el.remove();
      }

      function focusSection(el) {
        ensureNavStyles();
        el.classList.add('isbot-focus');
        setTimeout(function () { el.classList.remove('isbot-focus'); }, 2400);
      }

      function detectZona() {
        var recent = chatHistory.slice(-3).map(function (m) { return (m.content || '').toLowerCase(); }).join(' ');
        var zonas = ['barcelona', 'hospitalet', 'badalona', 'santa coloma', 'sant adria', 'cornella', 'esplugues', 'sant just', 'sant joan'];
        for (var i = 0; i < zonas.length; i++) {
          if (recent.indexOf(zonas[i]) >= 0) return zonas[i];
        }
        return null;
      }

      function highlightZona(zona) {
        if (!zona) return;
        var cards = document.querySelectorAll('[data-zona]');
        cards.forEach(function (card) {
          if ((card.getAttribute('data-zona') || '').indexOf(zona) >= 0) {
            card.classList.add('isbot-zona');
            setTimeout(function () { card.classList.remove('isbot-zona'); }, 3000);
          }
        });
      }

      function runNavigation(route) {
        if (!route) return false;
        var hashIndex = route.indexOf('#');
        var path = hashIndex >= 0 ? route.slice(0, hashIndex) : route;
        var anchor = hashIndex >= 0 ? route.slice(hashIndex + 1) : '';
        if (path === '') path = window.location.pathname;
        var samePage = path === window.location.pathname;
        var zona = anchor === 'zonas' ? detectZona() : null;
        var DELAY_SAME = 1800;
        var DELAY_CROSS = 2800;

        if (samePage) {
          if (anchor) {
            var el = document.getElementById(anchor);
            if (!el) return false;
            setTimeout(function () {
              el.scrollIntoView({ behavior: 'smooth' });
              focusSection(el);
              if (zona) setTimeout(function () { highlightZona(zona); }, 500);
            }, DELAY_SAME);
            return true;
          }
          setTimeout(function () { window.scrollTo({ top: 0, behavior: 'smooth' }); }, DELAY_SAME);
          return true;
        }

        if (!{
          '/': 1,
          '/nosotros': 1,
          '/contacto': 1,
          '/servicios': 1,
          '/servicios/instalaciones-electricas': 1,
          '/servicios/fontaneria-y-saneamiento': 1,
          '/servicios/climatizacion-y-calefaccion': 1,
          '/servicios/reformas-integrales': 1
        }[path]) return false;

        try {
          if (zona) sessionStorage.setItem('isbot-zona', zona);
        } catch (e) {}
        saveState();
        showChatNav(route.indexOf('#') >= 0 ? route : routeLabel(route));
        setTimeout(function () { showNavOverlay(routeLabel(route)); }, 900);
        setTimeout(function () { window.location.href = route; }, DELAY_CROSS);
        return true;
      }

      function routeLabel(route) {
        var map = {
          '/': 'el inicio',
          '/servicios': 'los servicios',
          '/#contacto': 'contacto',
          '/contacto': 'contacto',
          '/nosotros': 'sobre nosotros',
          '/estimador': 'el configurador 3D',
          '/servicios/instalaciones-electricas': 'Electricidad',
          '/servicios/fontaneria-y-saneamiento': 'Fontanería',
          '/servicios/climatizacion-y-calefaccion': 'Climatización',
          '/servicios/reformas-integrales': 'Reformas integrales'
        };
        return map[route] || 'la página';
      }

      function escapeHtml(text) {
        var d = document.createElement('div');
        d.textContent = text == null ? '' : String(text);
        return d.innerHTML;
      }

      function mdInline(s) {
        return s
          .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="text-primary font-medium underline">$1</a>')
          .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
          .replace(/__([^_]+)__/g, '<strong>$1</strong>');
      }

      function renderMarkdown(text) {
        var norm = text
          .replace(/([a-záéíóúñ0-9\)])\s*\*\s+(?=[A-ZÁÉÍÓÚ])/g, '$1\n- ')
          .replace(/\s+[•·]\s+/g, '\n- ');
        var lines = norm.split('\n');
        var out = [];
        var inList = false;
        function closeList() {
          if (inList) {
            out.push('</ul>');
            inList = false;
          }
        }
        lines.forEach(function (raw) {
          var line = raw.trim();
          if (!line) {
            closeList();
            return;
          }
          var m = line.match(/^[-*]\s+(.*)$/) || line.match(/^\d+[.)]\s+(.*)$/);
          var label = !m ? line.match(/^([A-ZÁÉÍÓÚÑ][^:.]{1,45}):\s+(.+)$/) : null;
          if (m) {
            if (!inList) {
              out.push('<ul class="list-disc pl-4 space-y-1 my-1.5">');
              inList = true;
            }
            out.push('<li>' + mdInline(m[1]) + '</li>');
          } else if (label) {
            if (!inList) {
              out.push('<ul class="list-disc pl-4 space-y-1 my-1.5">');
              inList = true;
            }
            out.push('<li><strong>' + label[1] + ':</strong> ' + mdInline(label[2]) + '</li>');
          } else {
            closeList();
            out.push('<p class="mb-1.5 last:mb-0">' + mdInline(line) + '</p>');
          }
        });
        closeList();
        return out.join('');
      }

      function createBotMessage() {
        var div = document.createElement('div');
        div.className = 'flex gap-2';
        div.innerHTML = '<img src="/isbot.png" alt="Bot" class="w-10 h-10 object-contain shrink-0" width="40" height="40" /><div class="bg-white p-3 rounded-2xl rounded-tl-sm shadow-sm border border-gray-100 max-w-[84%]"><div class="text-sm text-gray-700 bot-text chat-markdown"></div></div>';
        messagesEl.appendChild(div);
        scrollToBottom();
        return div.querySelector('.bot-text');
      }

      function addUserMessage(text) {
        var div = document.createElement('div');
        div.className = 'flex gap-2 justify-end';
        div.innerHTML = '<div class="bg-primary text-white p-3 rounded-2xl rounded-tr-sm shadow-sm max-w-[84%]"><p class="text-sm">' + escapeHtml(text) + '</p></div>';
        messagesEl.appendChild(div);
        scrollToBottom();
      }

      function showTyping() {
        var div = document.createElement('div');
        div.id = 'typing-indicator';
        div.className = 'flex gap-2';
