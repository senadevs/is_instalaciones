            + rest.map(function (image, index) {
              return '<div class="overflow-hidden rounded-[1.75rem] border border-white/70 bg-white shadow-xl">'
                + '<img src="' + escapeHtml(image) + '" alt="' + escapeHtml(title) + ' ' + (index + 2) + '" class="h-40 w-full object-cover" loading="lazy" />'
                + '</div>';
            }).join('')
            + '</div></div>'
            + (body ? '<p class="mt-3 max-w-2xl text-sm leading-relaxed text-slate-600 md:text-base">' + escapeHtml(body) + '</p>' : '')
            + '</div>'
            + '</div>';

          return canvas;
        }

        // Fallback: simple welcome/introduction when nothing else
        return '<div class="rounded-[2rem] border border-white/70 bg-white/80 p-6 shadow-2xl backdrop-blur-2xl md:p-8">' +
          '<div class="grid gap-6 lg:grid-cols-[1.15fr_.85fr] lg:items-center">' +
          '<div>' +
          '<div class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 py-2 text-sm font-semibold text-primary"><span class="h-2 w-2 rounded-full bg-primary"></span> Experiencia guiada</div>' +
          '<h2 class="mt-4 max-w-3xl text-4xl font-black tracking-tight text-slate-900 md:text-6xl">Modo inmersivo activo</h2>' +
          '<p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-600 md:text-lg">Pide al agente que componga texto e imágenes; aquí aparecerá la composición visual resultante.</p>' +
          '</div></div></div>';
      }

      function showImmersiveContent(signal) {
        if (!immersiveStage) return;
        var content = document.getElementById('immersive-content');
        var story = document.getElementById('immersive-story');
        if (!content || !story) return;

        // Render the visual canvas (images + composed text)
        content.innerHTML = renderImmersive(signal);

        // The story panel is reserved strictly for the agent narrative (no cards)
        story.innerHTML = '<div class="space-y-4">'
          + '<div class="rounded-[1.75rem] border border-emerald-100 bg-white/90 p-4 shadow-sm">'
          + '<p class="text-xs font-semibold uppercase tracking-[0.22em] text-emerald-700/80">Respuesta del agente</p>'
          + '<p class="mt-3 text-sm leading-relaxed text-slate-700">' + escapeHtml(lastImmersiveNarration || 'La respuesta del agente se mostrará aquí.') + '</p>'
          + '</div>'
          + '</div>';
      }

      function enterImmersiveMode() {
        if (!isDesktopImmersiveAllowed()) return;
        isImmersive = true;
        document.body.classList.add('immersive-mode');
        document.body.classList.add('chat-open');
        if (immersiveStage) immersiveStage.classList.remove('hidden');
        if (immersiveForm) immersiveForm.classList.remove('hidden');
        if (immersiveToggle) {
          immersiveToggle.setAttribute('aria-pressed', 'true');
          immersiveToggle.classList.add('bg-white/18');
        }
        // Initialize an empty canvas — the agent will compose visuals from the conversation
        lastImmersiveNarration = 'Modo inmersivo listo. Pide algo (por ejemplo: "Instalar aire y videoportero") y crearé la composición visual.';
        showImmersiveContent({ kind: 'scene', params: { title: '', lead: '', body: '' } });
        saveState();
      }

      function exitImmersiveMode() {
        isImmersive = false;
        document.body.classList.remove('immersive-mode');
        if (!isOpen) document.body.classList.remove('chat-open');
        if (immersiveStage) immersiveStage.classList.add('hidden');
        if (immersiveForm) immersiveForm.classList.add('hidden');
        if (immersiveToggle) {
          immersiveToggle.setAttribute('aria-pressed', 'false');
          immersiveToggle.classList.remove('bg-white/18');
        }
        var content = document.getElementById('immersive-content');
        if (content) content.innerHTML = '';
        saveState();
      }

      function setImmersiveAction(action) {
        if (!action) return;
        showImmersiveContent(action);
      }

      function toggleChat() {
        isOpen = !isOpen;
        chatWindow.style.display = isOpen ? 'flex' : 'none';
        iconOpen.classList.toggle('hidden', isOpen);
        iconClose.classList.toggle('hidden', !isOpen);
        if (isOpen) {
          notification.classList.add('hidden');
          var teaserEl = document.getElementById('chat-teaser');
          if (teaserEl) teaserEl.classList.add('hidden');
          document.body.classList.add('chat-open');
          chatWindow.style.flexDirection = 'column';
          input.focus();
        } else if (!isImmersive) {
          document.body.classList.remove('chat-open');
        }
        saveState();
      }

      function createToolChips() {
        return;
      }

      async function sendMessage(text) {
        if (!text.trim() || isStreaming) return;

        var activeInput = (immersiveInput && String(text).trim() === String(immersiveInput.value || '').trim()) ? immersiveInput : input;
        var qr = document.getElementById('chat-quick-replies');
        if (qr) qr.remove();

        addUserMessage(text);
        if (activeInput) activeInput.value = '';
        chatHistory.push({ role: 'user', content: text });
        saveState();

        setLoading(true);
        showTyping();
        // If immersive, show a loader in the canvas area so the user sees the agent 'thinking'
        if (isImmersive) {
          try {
            var _content = document.getElementById('immersive-content');
            if (_content) {
              _content.innerHTML = ''
                + '<div class="rounded-[1.5rem] p-8 text-center">'
                + '<div class="inline-flex items-center justify-center gap-3">'
                + '<svg class="animate-spin h-6 w-6 text-emerald-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">'
                + '<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>'
                + '<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>'
                + '<div class="text-sm text-slate-600">El agente está componiendo la escena...</div>'
                + '</div></div>';
            }
          } catch (e) {}
        }

        try {
          var response = await fetch('/api/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ messages: chatHistory, mode: isImmersive ? 'immersive' : 'normal' }),
          });

          removeTyping();

          if (!response.ok) throw new Error('API error');

          var botTextEl = createBotMessage();
          var fullText = '';
          var reader = response.body.getReader();
          var decoder = new TextDecoder();

          while (true) {
            var result = await reader.read();
            if (result.done) break;
            var chunk = decoder.decode(result.value, { stream: true });
            fullText += chunk;
            botTextEl.innerHTML = renderMarkdown(fullText.split('[[')[0]);
            messagesEl.scrollTop = messagesEl.scrollHeight;
          }

          // Limpia los marcadores del texto del asistente, incluido un marcador
          // truncado al final por el corte del stream (p. ej. "[[GOTO:/contac").
          var cleaned = fullText
            .replace(/\[\[GOTO:[^\]]+\]\]/ig, '')
            .replace(/\[\[SHOW:[^\]]+\]\]/ig, '')
            .replace(/\[\[(GOTO|SHOW):[^\]]*$/i, '')
            .trim();

          if (!isImmersive) {
            // ---- CHAT NORMAL: respuesta COMPLETA + navegación opcional ----
            // (no se parte en párrafos ni se toca el estado del modo inmersivo)
            var nav = extractNavigation(fullText);
            var text = cleaned || (nav.route ? 'Te llevo allí 👇' : '');
            botTextEl.innerHTML = renderMarkdown(text);
            scrollToBottom();
            chatHistory.push({ role: 'assistant', content: text });
            if (chatHistory.length > 10) chatHistory = chatHistory.slice(-10);
            saveState();
            if (nav.route) {
              var ok = runNavigation(nav.route);
              if (!ok) {
                var fb = createBotMessage();
                fb.innerHTML = renderMarkdown('No he podido abrir esa sección, pero te ayudo por aquí. ¿Qué necesitas exactamente? 🙂');
                chatHistory.push({ role: 'assistant', content: 'No he podido abrir esa sección, pero te ayudo por aquí. ¿Qué necesitas exactamente?' });
                scrollToBottom();
              }
            }
          } else {
            // ---- MODO INMERSIVO: narrativa breve + escena visual ----
            var showInfo = extractShow(fullText);
            var parts = cleaned.split(/\n\s*\n/).map(function (p) { return p.trim(); }).filter(Boolean);
            var narrative = parts.length ? parts[0] : (cleaned || '');
            var visualInstr = parts.length > 1 ? parts.slice(1).join('\n\n') : '';
            if (!narrative) narrative = 'Te lo muestro aquí 👇';
            botTextEl.innerHTML = renderMarkdown(narrative);
            scrollToBottom();
            lastImmersiveNarration = narrative;
            chatHistory.push({ role: 'assistant', content: narrative });
            if (chatHistory.length > 10) chatHistory = chatHistory.slice(-10);
            saveState();
            if (showInfo.kind) {
              setImmersiveAction(showInfo);
            } else {
              var seed = visualInstr || '';
              var seedTitle = seed ? seed.split('\n')[0].slice(0, 180) : (narrative || '').split('.').slice(0, 1).join('.').slice(0, 160);
              setImmersiveAction({ kind: 'scene', params: { title: seedTitle, body: seed || '', images: undefined } });
            }
          }
        } catch (err) {
          removeTyping();
          var errorEl = createBotMessage();
          errorEl.textContent = 'Lo siento, ha ocurrido un error. Puedes contactarnos directamente al 637 59 17 36 o por WhatsApp.';
        }

        setLoading(false);
      }

      toggle.addEventListener('click', toggleChat);
      closeBtn.addEventListener('click', toggleChat);
      if (immersiveToggle) {
        immersiveToggle.addEventListener('click', function () {
          if (isImmersive) {
            exitImmersiveMode();
          } else {
            enterImmersiveMode();
          }
        });
      }
      if (immersiveClose) immersiveClose.addEventListener('click', exitImmersiveMode);

      if (immersiveStage) {
        immersiveStage.addEventListener('click', function (event) {
          var target = event.target.closest('[data-immersive-action]');
          if (!target) return;
          setImmersiveAction(target.getAttribute('data-immersive-action'));
        });
      }

      form.addEventListener('submit', function (event) {
        event.preventDefault();
        sendMessage(input.value);
      });

      if (immersiveForm) {
        immersiveForm.addEventListener('submit', function (event) {
          event.preventDefault();
          if (immersiveInput) sendMessage(immersiveInput.value);
        });
      }

      quickReplies.forEach(function (btn) {
        btn.addEventListener('click', function () {
          sendMessage(btn.textContent.trim());
        });
      });

      createToolChips();

      (function restore() {
        var state = readState();
        if (!state) return;

        if (state.history && state.history.length) {
          var qr = document.getElementById('chat-quick-replies');
          if (qr) qr.remove();
          state.history.forEach(function (msg) {
            if (msg.role === 'user') {
              addUserMessage(msg.content);
            } else if (msg.role === 'assistant') {
              var el = createBotMessage();
              el.innerHTML = renderMarkdown(msg.content);
            }
          });
          chatHistory = state.history;
          scrollToBottom();
        }

        if (state.open) {
          isOpen = false;
          toggleChat();
          scrollToBottom();
        }

        if (state.immersive && isDesktopImmersiveAllowed()) {
          enterImmersiveMode();
        } else if (state.immersive) {
          exitImmersiveMode();
        }
      })();

      (function setupTeaser() {
        var teaser = document.getElementById('chat-teaser');
        var teaserClose = document.getElementById('chat-teaser-close');
        var teaserText = document.getElementById('chat-teaser-text');
        if (!teaser || !teaserText) return;

        var dismissed = false;
        try { dismissed = sessionStorage.getItem('isbot-teaser') === '1'; } catch (e) {}
        if (dismissed) return;

        var mensajes = [
          '¿Buscas un servicio concreto?',
          'Te llevo a reformas, electricidad o climatización.',
          '¿Quieres ver trabajos reales?',
          'Pide contacto y lo abrimos sin rodeos.'
        ];
        var idx = 0;
        var rotTimer;
        teaserText.style.transition = 'opacity .2s ease';

        function hideTeaser() {
          teaser.classList.add('hidden');
          if (rotTimer) clearInterval(rotTimer);
        }

        function dismissTeaser() {
          hideTeaser();
          try { sessionStorage.setItem('isbot-teaser', '1'); } catch (e) {}
        }

        function showTeaser() {
          if (isOpen) return;
          teaser.classList.remove('hidden');
          rotTimer = setInterval(function () {
            if (isOpen) return;
            idx = (idx + 1) % mensajes.length;
            teaserText.style.opacity = '0';
            setTimeout(function () {
              teaserText.textContent = mensajes[idx];
              teaserText.style.opacity = '1';
            }, 250);
          }, 8000);
        }

        setTimeout(function () { if (!isOpen) showTeaser(); }, 5000);

        teaser.addEventListener('click', function (event) {
          if (event.target.closest('#chat-teaser-close')) return;
          dismissTeaser();
          if (!isOpen) toggleChat();
        });

        teaserClose.addEventListener('click', function (event) {
          event.stopPropagation();
          dismissTeaser();
        });
      })();

      (function pendingFocus() {
        var zona;
        try {
          zona = sessionStorage.getItem('isbot-zona');
          sessionStorage.removeItem('isbot-zona');
        } catch (e) {}

        var hash = window.location.hash ? window.location.hash.substring(1) : '';
        if (hash) {
          var sec = document.getElementById(hash);
          if (sec) setTimeout(function () { focusSection(sec); }, 500);
        }
        if (zona) setTimeout(function () { highlightZona(zona); }, 800);
      })();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initChat);
    } else {
      initChat();
    }
    document.addEventListener('astro:page-load', initChat);
  })();
</script>
