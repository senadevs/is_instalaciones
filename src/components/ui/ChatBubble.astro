---
import { Icon } from 'astro-icon/components';
---

<!-- Chat Bubble -->
<div id="chat-widget" class="fixed bottom-6 right-6 z-50">

  <!-- Chat Window -->
  <div
    id="chat-window"
    class="fixed md:absolute inset-0 md:inset-auto md:bottom-20 md:right-0 w-full md:w-[360px] md:max-w-[calc(100vw-2rem)] bg-white md:rounded-2xl shadow-2xl md:border md:border-gray-200 overflow-hidden z-[60]"
    style="display: none;"
  >
    {/* Header */}
    <div class="bg-primary p-4 flex items-center justify-between shrink-0">
      <div class="flex items-center gap-3">
        <img src="/isbot.png" alt="IS Bot" class="w-12 h-12 object-contain" width="48" height="48" />
        <div>
          <p class="text-white font-semibold text-sm">IS Instalaciones</p>
          <div class="flex items-center gap-1.5">
            <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
            <span class="text-white/70 text-xs">En línea</span>
          </div>
        </div>
      </div>
      <button
        id="chat-close"
        class="text-white/70 hover:text-white transition-colors p-1"
        aria-label="Cerrar chat"
      >
        <Icon name="lucide:x" class="w-5 h-5" />
      </button>
    </div>

    {/* Messages area */}
    <div id="chat-messages" class="flex-1 md:h-80 md:flex-none overflow-y-auto p-4 space-y-3 bg-gray-50">
      {/* Welcome message */}
      <div class="flex gap-2">
        <img src="/isbot.png" alt="IS Bot" class="w-10 h-10 object-contain shrink-0" width="40" height="40" />
        <div class="bg-white p-3 rounded-2xl rounded-tl-sm shadow-sm border border-gray-100 max-w-[80%]">
          <p class="text-sm text-gray-700">
            Hola, soy el asistente de <strong>IS Instalaciones</strong>. ¿En qué puedo ayudarte?
          </p>
        </div>
      </div>

      {/* Quick replies */}
      <div id="chat-quick-replies" class="flex flex-wrap gap-2 pl-10">
        <button class="chat-quick-reply text-xs bg-primary text-white px-3 py-1.5 rounded-full hover:bg-secondary transition-colors">
          Qué servicios ofrecéis
        </button>
        <button class="chat-quick-reply text-xs bg-primary text-white px-3 py-1.5 rounded-full hover:bg-secondary transition-colors">
          Zonas de cobertura
        </button>
        <button class="chat-quick-reply text-xs bg-primary text-white px-3 py-1.5 rounded-full hover:bg-secondary transition-colors">
          Horario de atención
        </button>
      </div>
    </div>

    {/* Input area */}
    <div class="p-3 border-t border-gray-200 bg-white shrink-0">
      <form id="chat-form" class="flex items-center gap-2">
        <input
          id="chat-input"
          type="text"
          placeholder="Escribe tu mensaje..."
          class="flex-1 px-4 py-2.5 rounded-xl border border-gray-200 bg-gray-50 text-sm focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
          autocomplete="off"
        />
        <button
          type="submit"
          class="w-10 h-10 bg-primary text-white rounded-xl flex items-center justify-center hover:bg-secondary transition-colors shrink-0"
          aria-label="Enviar mensaje"
        >
          <Icon name="lucide:send" class="w-4 h-4" />
        </button>
      </form>
    </div>
  </div>

  <!-- Floating Button -->
  <button
    id="chat-toggle"
    class="chat-bubble-btn w-16 h-16 bg-white rounded-full shadow-lg hover:shadow-xl flex items-center justify-center hover:scale-110 transition-all duration-300 relative border-2 border-primary/20"
    aria-label="Abrir chat"
  >
    <img src="/isbot.png" alt="Chat" id="chat-icon-open" class="w-14 h-14 object-contain" width="56" height="56" />
    <Icon name="lucide:x" id="chat-icon-close" class="w-7 h-7 text-primary hidden" />

    {/* Notification dot */}
    <span id="chat-notification" class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 rounded-full border-2 border-white animate-pulse"></span>
  </button>
</div>

<script is:inline>
  (function() {
    function initChat() {
      var toggle = document.getElementById('chat-toggle');
      var chatWindow = document.getElementById('chat-window');
      var closeBtn = document.getElementById('chat-close');
      var form = document.getElementById('chat-form');
      var input = document.getElementById('chat-input');
      var messagesEl = document.getElementById('chat-messages');
      var iconOpen = document.getElementById('chat-icon-open');
      var iconClose = document.getElementById('chat-icon-close');
      var notification = document.getElementById('chat-notification');
      var quickReplies = document.querySelectorAll('.chat-quick-reply');
      var submitBtn = form ? form.querySelector('button[type="submit"]') : null;

      if (!toggle || !chatWindow || !form || !input || !messagesEl) return;
      if (toggle.dataset.chatInit === 'true') return;
      toggle.dataset.chatInit = 'true';

      var isOpen = false;
      var isStreaming = false;
      var chatHistory = [];

      function toggleChat() {
        isOpen = !isOpen;
        chatWindow.style.display = isOpen ? 'flex' : 'none';
        iconOpen.classList.toggle('hidden', isOpen);
        iconClose.classList.toggle('hidden', !isOpen);
        if (isOpen) {
          notification.classList.add('hidden');
          document.body.classList.add('chat-open');
          chatWindow.style.flexDirection = 'column';
          input.focus();
        } else {
          document.body.classList.remove('chat-open');
        }
      }

      toggle.addEventListener('click', toggleChat);
      closeBtn.addEventListener('click', toggleChat);

      function addUserMessage(text) {
        var div = document.createElement('div');
        div.className = 'flex gap-2 justify-end';
        div.innerHTML = '<div class="bg-primary text-white p-3 rounded-2xl rounded-tr-sm shadow-sm max-w-[80%]"><p class="text-sm">' + escapeHtml(text) + '</p></div>';
        messagesEl.appendChild(div);
        messagesEl.scrollTop = messagesEl.scrollHeight;
      }

      function createBotMessage() {
        var div = document.createElement('div');
        div.className = 'flex gap-2';
        div.innerHTML = '<img src="/isbot.png" alt="Bot" class="w-10 h-10 object-contain shrink-0" width="40" height="40" /><div class="bg-white p-3 rounded-2xl rounded-tl-sm shadow-sm border border-gray-100 max-w-[80%]"><div class="text-sm text-gray-700 bot-text chat-markdown"></div></div>';
        messagesEl.appendChild(div);
        messagesEl.scrollTop = messagesEl.scrollHeight;
        return div.querySelector('.bot-text');
      }

      function renderMarkdown(text) {
        var html = text
          .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
          .replace(/\*(.*?)\*/g, '<em>$1</em>')
          .replace(/^- (.+)/gm, '<li>$1</li>')
          .replace(/^\d+\. (.+)/gm, '<li>$1</li>')
          .replace(/(<li>.*<\/li>)/s, '<ul class="list-disc pl-4 space-y-1 my-1">$1</ul>')
          .replace(/\n\n/g, '</p><p class="mt-2">')
          .replace(/\n/g, '<br>');
        return '<p>' + html + '</p>';
      }

      function showTyping() {
        var div = document.createElement('div');
        div.id = 'typing-indicator';
        div.className = 'flex gap-2';
        div.innerHTML = '<img src="/isbot.png" alt="Bot" class="w-10 h-10 object-contain shrink-0" width="40" height="40" /><div class="bg-white p-3 rounded-2xl rounded-tl-sm shadow-sm border border-gray-100"><div class="flex gap-1"><span class="w-2 h-2 bg-gray-300 rounded-full animate-bounce" style="animation-delay:0s"></span><span class="w-2 h-2 bg-gray-300 rounded-full animate-bounce" style="animation-delay:0.15s"></span><span class="w-2 h-2 bg-gray-300 rounded-full animate-bounce" style="animation-delay:0.3s"></span></div></div>';
        messagesEl.appendChild(div);
        messagesEl.scrollTop = messagesEl.scrollHeight;
      }

      function removeTyping() {
        var el = document.getElementById('typing-indicator');
        if (el) el.remove();
      }

      function escapeHtml(text) {
        var d = document.createElement('div');
        d.textContent = text;
        return d.innerHTML;
      }

      function setLoading(loading) {
        isStreaming = loading;
        if (submitBtn) {
          submitBtn.disabled = loading;
          submitBtn.style.opacity = loading ? '0.5' : '1';
        }
        input.disabled = loading;
      }

      async function sendMessage(text) {
        if (!text.trim() || isStreaming) return;

        // Hide quick replies
        var qr = document.getElementById('chat-quick-replies');
        if (qr) qr.remove();

        addUserMessage(text);
        input.value = '';
        chatHistory.push({ role: 'user', content: text });

        setLoading(true);
        showTyping();

        try {
          var response = await fetch('/api/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ messages: chatHistory }),
          });

          removeTyping();

          if (!response.ok) throw new Error('API error');

          var botTextEl = createBotMessage();
          var fullText = '';

          // Read text stream
          var reader = response.body.getReader();
          var decoder = new TextDecoder();

          while (true) {
            var result = await reader.read();
            if (result.done) break;

            var chunk = decoder.decode(result.value, { stream: true });
            fullText += chunk;
            botTextEl.textContent = fullText;
            messagesEl.scrollTop = messagesEl.scrollHeight;
          }

          // Render markdown after stream completes
          botTextEl.innerHTML = renderMarkdown(fullText);

          chatHistory.push({ role: 'assistant', content: fullText });

          // Keep history manageable (last 10 messages)
          if (chatHistory.length > 10) {
            chatHistory = chatHistory.slice(-10);
          }

        } catch (err) {
          removeTyping();
          var errorEl = createBotMessage();
          errorEl.textContent = 'Lo siento, ha ocurrido un error. Puedes contactarnos directamente al 637 59 17 36 o por WhatsApp.';
        }

        setLoading(false);
      }

      form.addEventListener('submit', function(e) {
        e.preventDefault();
        sendMessage(input.value);
      });

      quickReplies.forEach(function(btn) {
        btn.addEventListener('click', function() {
          sendMessage(btn.textContent.trim());
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initChat);
    } else {
      initChat();
    }
    document.addEventListener('astro:page-load', initChat);
  })();
</script>
