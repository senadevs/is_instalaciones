---
import { Icon } from 'astro-icon/components';
---

<!-- Chat Bubble -->
<div id="chat-widget" class="fixed bottom-6 right-6 z-50">

  <!-- Chat Window -->
  <div
    id="chat-window"
    class="fixed md:absolute inset-0 md:inset-auto md:bottom-20 md:right-0 w-full md:w-[360px] md:max-w-[calc(100vw-2rem)] bg-white md:rounded-2xl shadow-2xl md:border md:border-gray-200 overflow-hidden z-[60]"
    style="display: none;"
  >
    {/* Header */}
    <div class="bg-primary p-4 flex items-center justify-between shrink-0">
      <div class="flex items-center gap-3">
        <img src="/isbot.png" alt="IS Bot" class="w-12 h-12 object-contain" width="48" height="48" />
        <div>
          <p class="text-white font-semibold text-sm">IS Instalaciones</p>
          <div class="flex items-center gap-1.5">
            <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
            <span class="text-white/70 text-xs">En línea</span>
          </div>
        </div>
      </div>
      <button
        id="chat-close"
        class="text-white/70 hover:text-white transition-colors p-1"
        aria-label="Cerrar chat"
      >
        <Icon name="lucide:x" class="w-5 h-5" />
      </button>
    </div>

    {/* Messages area */}
    <div id="chat-messages" class="flex-1 md:h-[460px] md:flex-none overflow-y-auto p-4 space-y-3 bg-gray-50">
      {/* Welcome message */}
      <div class="flex gap-2">
        <img src="/isbot.png" alt="IS Bot" class="w-10 h-10 object-contain shrink-0" width="40" height="40" />
        <div class="bg-white p-3 rounded-2xl rounded-tl-sm shadow-sm border border-gray-100 max-w-[80%]">
          <p class="text-sm text-gray-700">
            Hola, soy el asistente de <strong>IS Instalaciones</strong>. ¿En qué puedo ayudarte?
          </p>
        </div>
      </div>

      {/* Quick replies */}
      <div id="chat-quick-replies" class="flex flex-wrap gap-2 pl-10">
        <button class="chat-quick-reply text-xs bg-primary text-white px-3 py-1.5 rounded-full hover:bg-secondary transition-colors">
          Qué servicios ofrecéis
        </button>
        <button class="chat-quick-reply text-xs bg-primary text-white px-3 py-1.5 rounded-full hover:bg-secondary transition-colors">
          Zonas de cobertura
        </button>
        <button class="chat-quick-reply text-xs bg-primary text-white px-3 py-1.5 rounded-full hover:bg-secondary transition-colors">
          Horario de atención
        </button>
      </div>
    </div>

    {/* Input area */}
    <div class="p-3 border-t border-gray-200 bg-white shrink-0">
      <form id="chat-form" class="flex items-center gap-2">
        <input
          id="chat-input"
          type="text"
          placeholder="Escribe tu mensaje..."
          class="flex-1 px-4 py-2.5 rounded-xl border border-gray-200 bg-gray-50 text-sm focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
          autocomplete="off"
        />
        <button
          type="submit"
          class="w-10 h-10 bg-primary text-white rounded-xl flex items-center justify-center hover:bg-secondary transition-colors shrink-0"
          aria-label="Enviar mensaje"
        >
          <Icon name="lucide:send" class="w-4 h-4" />
        </button>
      </form>
    </div>
  </div>

  <!-- Teaser: burbuja que invita a usar el bot -->
  <div
    id="chat-teaser"
    class="absolute bottom-20 right-0 w-60 bg-white rounded-2xl rounded-br-sm shadow-xl border border-gray-100 p-3.5 pr-8 hidden"
  >
    <button id="chat-teaser-close" class="absolute top-2 right-2 text-gray-400 hover:text-gray-600" aria-label="Cerrar">
      <Icon name="lucide:x" class="w-3.5 h-3.5" />
    </button>
    <div class="flex items-start gap-2.5">
      <img src="/isbot.png" alt="IS Bot" class="w-9 h-9 object-contain shrink-0" width="36" height="36" />
      <p id="chat-teaser-text" class="text-sm text-gray-700 leading-snug">
        ¡Hola! ¿Te ayudo a encontrar lo que buscas?
      </p>
    </div>
  </div>

  <!-- Floating Button -->
  <button
    id="chat-toggle"
    class="chat-bubble-btn w-16 h-16 bg-white rounded-full shadow-lg hover:shadow-xl flex items-center justify-center hover:scale-110 transition-all duration-300 relative border-2 border-primary/20"
    aria-label="Abrir chat"
  >
    <img src="/isbot.png" alt="Chat" id="chat-icon-open" class="w-14 h-14 object-contain" width="56" height="56" />
    <Icon name="lucide:x" id="chat-icon-close" class="w-7 h-7 text-primary hidden" />

    {/* Notification dot */}
    <span id="chat-notification" class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 rounded-full border-2 border-white animate-pulse"></span>
  </button>
</div>

<script is:inline>
  (function() {
    function initChat() {
      var toggle = document.getElementById('chat-toggle');
      var chatWindow = document.getElementById('chat-window');
      var closeBtn = document.getElementById('chat-close');
      var form = document.getElementById('chat-form');
      var input = document.getElementById('chat-input');
      var messagesEl = document.getElementById('chat-messages');
      var iconOpen = document.getElementById('chat-icon-open');
      var iconClose = document.getElementById('chat-icon-close');
      var notification = document.getElementById('chat-notification');
      var quickReplies = document.querySelectorAll('.chat-quick-reply');
      var submitBtn = form ? form.querySelector('button[type="submit"]') : null;

      if (!toggle || !chatWindow || !form || !input || !messagesEl) return;
      if (toggle.dataset.chatInit === 'true') return;
      toggle.dataset.chatInit = 'true';

      var isOpen = false;
      var isStreaming = false;
      var chatHistory = [];
      var STORAGE_KEY = 'isbot-chat';

      // Persistimos la conversacion para que sobreviva a la navegacion entre
      // paginas (el sitio recarga, no es SPA). Asi el agente puede llevar al
      // usuario a otra pagina sin perder el hilo del chat.
      function saveState() {
        try {
          sessionStorage.setItem(STORAGE_KEY, JSON.stringify({ open: isOpen, history: chatHistory }));
        } catch (e) {}
      }

      // Detecta el marcador [[GOTO:ruta]] que emite el agente, lo separa del
      // texto visible y devuelve la ruta para navegar.
      function extractNavigation(text) {
        var m = text.match(/\[\[GOTO:\s*([^\]]+)\]\]/i);
        if (!m) return { clean: text, route: null };
        var clean = text.replace(/\[\[GOTO:[^\]]+\]\]/ig, '').trim();
        return { clean: clean, route: m[1].trim() };
      }

      // Baja el chat al ultimo mensaje (tras render, con doble RAF para que
      // el navegador haya recalculado la altura del contenido markdown).
      function scrollToBottom() {
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            messagesEl.scrollTop = messagesEl.scrollHeight;
          });
        });
      }

      // Rutas validas del sitio. Si el agente pide navegar a una ruta que no
      // existe, NO navegamos (evita 404 / "tool fallida").
      var VALID_PATHS = {
        '/': 1,
        '/nosotros': 1,
        '/contacto': 1,
        '/estimador': 1,
        '/servicios': 1,
        '/servicios/instalaciones-electricas': 1,
        '/servicios/fontaneria-y-saneamiento': 1,
        '/servicios/climatizacion-y-calefaccion': 1,
        '/servicios/reformas-integrales': 1
      };

      // Nombre amigable de cada ruta para el loader.
      function routeLabel(route) {
        var map = {
          '/': 'el inicio',
          '/servicios': 'los servicios',
          '/#servicios': 'los servicios',
          '/#contacto': 'contacto',
          '/contacto': 'contacto',
          '/nosotros': 'sobre nosotros',
          '/estimador': 'el configurador 3D',
          '/servicios/instalaciones-electricas': 'Electricidad',
          '/servicios/fontaneria-y-saneamiento': 'Fontanería',
          '/servicios/climatizacion-y-calefaccion': 'Climatización',
          '/servicios/reformas-integrales': 'Reformas integrales'
        };
        return map[route] || 'la página';
      }

      // Inyecta una sola vez los estilos de animacion y resaltado.
      function ensureNavStyles() {
        if (document.getElementById('isbot-anim')) return;
        var st = document.createElement('style');
        st.id = 'isbot-anim';
        st.textContent =
          '@keyframes isbot-spin{to{transform:rotate(360deg)}}' +
          '.isbot-focus{box-shadow:0 0 0 3px rgba(29,78,216,.55),0 0 26px rgba(29,78,216,.35)!important;border-radius:14px;transition:box-shadow .4s ease;scroll-margin-top:7rem;}' +
          '.isbot-zona{box-shadow:0 0 0 3px rgba(29,78,216,.7)!important;transform:scale(1.05);z-index:2;}';
        document.head.appendChild(st);
      }

      // Overlay de carga. Va POR DEBAJO del chat (z-55 < chat z-60) para que
      // el usuario siga viendo lo que dice el agente mientras navega.
      function showNavOverlay(label) {
        ensureNavStyles();
        var accent = '#1d4ed8';
        try {
          var h = document.querySelector('header');
          if (h) { var c = getComputedStyle(h).backgroundColor; if (c && c !== 'rgba(0, 0, 0, 0)') accent = c; }
        } catch (e) {}
        var ov = document.createElement('div');
        ov.id = 'isbot-nav-overlay';
        ov.style.cssText = 'position:fixed;inset:0;z-index:55;display:flex;align-items:center;justify-content:center;background:rgba(15,23,42,.4);backdrop-filter:blur(3px);-webkit-backdrop-filter:blur(3px);opacity:0;transition:opacity .25s ease;';
        ov.innerHTML = '<div style="background:#fff;padding:20px 24px;border-radius:16px;box-shadow:0 12px 45px rgba(0,0,0,.25);display:flex;flex-direction:column;align-items:center;gap:12px;max-width:240px;text-align:center;">'
          + '<div style="width:36px;height:36px;border:3px solid #e5e7eb;border-top-color:' + accent + ';border-radius:50%;animation:isbot-spin .8s linear infinite;"></div>'
          + '<p style="font-size:13px;color:#374151;margin:0;font-weight:500;">Te llevo a <b>' + label + '</b>…</p></div>';
        // Lo anexamos dentro del widget (que es z-50) para que el chat-window
        // (z-60) quede por encima del overlay (z-55) y siga visible.
        var widget = document.getElementById('chat-widget') || document.body;
        widget.appendChild(ov);
        requestAnimationFrame(function () { ov.style.opacity = '1'; });
      }

      // Indicador de navegacion DENTRO del chat (load en el propio chat).
      function showChatNav(label) {
        ensureNavStyles();
        removeChatNav();
        var div = document.createElement('div');
        div.id = 'chat-nav-indicator';
        div.className = 'flex gap-2';
        div.innerHTML = '<img src="/isbot.png" alt="Bot" class="w-10 h-10 object-contain shrink-0" width="40" height="40" />'
          + '<div class="bg-primary/10 text-primary p-3 rounded-2xl rounded-tl-sm border border-primary/20 max-w-[85%] flex items-center gap-2">'
          + '<span style="width:14px;height:14px;border:2px solid currentColor;border-top-color:transparent;border-radius:50%;display:inline-block;animation:isbot-spin .8s linear infinite;"></span>'
          + '<span class="text-sm font-medium">Te llevo a ' + label + '…</span></div>';
        messagesEl.appendChild(div);
        messagesEl.scrollTop = messagesEl.scrollHeight;
      }
      function removeChatNav() {
        var e = document.getElementById('chat-nav-indicator');
        if (e) e.remove();
      }

      // Resaltado (glow) de la seccion de destino, como "seleccion" de contexto.
      function focusSection(el) {
        ensureNavStyles();
        el.classList.add('isbot-focus');
        setTimeout(function () { el.classList.remove('isbot-focus'); }, 2400);
      }

      // Busca en la conversacion reciente una zona de cobertura mencionada.
      var ZONAS = ['barcelona', 'hospitalet', 'badalona', 'santa coloma', 'sant adria', 'cornella', 'esplugues', 'sant just', 'sant joan'];
      function detectZona() {
        var recent = chatHistory.slice(-3).map(function (m) { return (m.content || '').toLowerCase(); }).join(' ');
        for (var i = 0; i < ZONAS.length; i++) {
          if (recent.indexOf(ZONAS[i]) >= 0) return ZONAS[i];
        }
        return null;
      }
      // Resalta la tarjeta de una zona concreta dentro de la seccion de zonas.
      function highlightZona(zona) {
        if (!zona) return;
        var cards = document.querySelectorAll('[data-zona]');
        cards.forEach(function (card) {
          if ((card.getAttribute('data-zona') || '').indexOf(zona) >= 0) {
            card.classList.add('isbot-zona');
            setTimeout(function () { card.classList.remove('isbot-zona'); }, 3000);
          }
        });
      }

      // Ejecuta la navegacion asistida. Devuelve true si pudo, false si la
      // "tool" fallo (ruta invalida o seccion inexistente) para que el chat
      // lo sepa y no deje al usuario colgado.
      function runNavigation(route) {
        if (!route) return false;
        var hashIndex = route.indexOf('#');
        var path = hashIndex >= 0 ? route.slice(0, hashIndex) : route;
        var anchor = hashIndex >= 0 ? route.slice(hashIndex + 1) : '';
        if (path === '') path = window.location.pathname;
        var samePage = path === window.location.pathname;
        var zona = anchor === 'zonas' ? detectZona() : null;

        // Pausas para que el usuario alcance a leer la respuesta del agente
        // antes de que la pagina se mueva o cambie.
        var DELAY_SAME = 1800;
        var DELAY_CROSS = 2800;

        if (samePage) {
          if (anchor) {
            var el = document.getElementById(anchor);
            if (!el) return false; // la seccion pedida no existe en esta pagina
            setTimeout(function () {
              el.scrollIntoView({ behavior: 'smooth' });
              focusSection(el);
              if (zona) setTimeout(function () { highlightZona(zona); }, 500);
            }, DELAY_SAME);
            return true;
          }
          setTimeout(function () { window.scrollTo({ top: 0, behavior: 'smooth' }); }, DELAY_SAME);
          return true;
        }

        // Otra pagina: validamos que la ruta exista antes de saltar.
        if (!VALID_PATHS[path]) return false;
        try {
          if (zona) sessionStorage.setItem('isbot-zona', zona);
        } catch (e) {}
        saveState();
        showChatNav(routeLabel(route));
        // El overlay aparece un momento despues, no de golpe, para que se lea.
        setTimeout(function () { showNavOverlay(routeLabel(route)); }, 900);
        // Pausa para que el usuario lea el mensaje antes de saltar de pagina.
        setTimeout(function () { window.location.href = route; }, DELAY_CROSS);
        return true;
      }

      function toggleChat() {
        isOpen = !isOpen;
        chatWindow.style.display = isOpen ? 'flex' : 'none';
        iconOpen.classList.toggle('hidden', isOpen);
        iconClose.classList.toggle('hidden', !isOpen);
        if (isOpen) {
          notification.classList.add('hidden');
          var teaserEl = document.getElementById('chat-teaser');
          if (teaserEl) teaserEl.classList.add('hidden');
          document.body.classList.add('chat-open');
          chatWindow.style.flexDirection = 'column';
          input.focus();
        } else {
          document.body.classList.remove('chat-open');
        }
        saveState();
      }

      toggle.addEventListener('click', toggleChat);
      closeBtn.addEventListener('click', toggleChat);

      function addUserMessage(text) {
        var div = document.createElement('div');
        div.className = 'flex gap-2 justify-end';
        div.innerHTML = '<div class="bg-primary text-white p-3 rounded-2xl rounded-tr-sm shadow-sm max-w-[80%]"><p class="text-sm">' + escapeHtml(text) + '</p></div>';
        messagesEl.appendChild(div);
        messagesEl.scrollTop = messagesEl.scrollHeight;
      }

      function createBotMessage() {
        var div = document.createElement('div');
        div.className = 'flex gap-2';
        div.innerHTML = '<img src="/isbot.png" alt="Bot" class="w-10 h-10 object-contain shrink-0" width="40" height="40" /><div class="bg-white p-3 rounded-2xl rounded-tl-sm shadow-sm border border-gray-100 max-w-[80%]"><div class="text-sm text-gray-700 bot-text chat-markdown"></div></div>';
        messagesEl.appendChild(div);
        messagesEl.scrollTop = messagesEl.scrollHeight;
        return div.querySelector('.bot-text');
      }

      function mdInline(s) {
        return s
          .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="text-primary font-medium underline">$1</a>')
          .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
          .replace(/__([^_]+)__/g, '<strong>$1</strong>');
      }

      function renderMarkdown(text) {
        // Normaliza vinetas pegadas que a veces genera el modelo
        // ("...fugas* Climatizacion") metiendoles su salto de linea.
        var norm = text
          .replace(/([a-záéíóúñ0-9\)])\s*\*\s+(?=[A-ZÁÉÍÓÚ])/g, '$1\n- ')
          .replace(/\s+[•·]\s+/g, '\n- ');

        var lines = norm.split('\n');
        var out = [];
        var inList = false;
        function closeList() { if (inList) { out.push('</ul>'); inList = false; } }

        lines.forEach(function(raw) {
          var line = raw.trim();
          if (!line) { closeList(); return; }
          var m = line.match(/^[-*]\s+(.*)$/) || line.match(/^\d+[.)]\s+(.*)$/);
          // Patron "Etiqueta corta: descripcion" -> item con etiqueta en negrita,
          // aunque el modelo no haya usado markdown.
          var label = !m ? line.match(/^([A-ZÁÉÍÓÚÑ][^:.]{1,45}):\s+(.+)$/) : null;
          if (m) {
            if (!inList) { out.push('<ul class="list-disc pl-4 space-y-1 my-1.5">'); inList = true; }
            out.push('<li>' + mdInline(m[1]) + '</li>');
          } else if (label) {
            if (!inList) { out.push('<ul class="list-disc pl-4 space-y-1 my-1.5">'); inList = true; }
            out.push('<li><strong>' + label[1] + ':</strong> ' + mdInline(label[2]) + '</li>');
          } else {
            closeList();
            out.push('<p class="mb-1.5 last:mb-0">' + mdInline(line) + '</p>');
          }
        });
        closeList();
        return out.join('');
      }

      function showTyping() {
        var div = document.createElement('div');
        div.id = 'typing-indicator';
        div.className = 'flex gap-2';
        div.innerHTML = '<img src="/isbot.png" alt="Bot" class="w-10 h-10 object-contain shrink-0" width="40" height="40" /><div class="bg-white p-3 rounded-2xl rounded-tl-sm shadow-sm border border-gray-100"><div class="flex gap-1"><span class="w-2 h-2 bg-gray-300 rounded-full animate-bounce" style="animation-delay:0s"></span><span class="w-2 h-2 bg-gray-300 rounded-full animate-bounce" style="animation-delay:0.15s"></span><span class="w-2 h-2 bg-gray-300 rounded-full animate-bounce" style="animation-delay:0.3s"></span></div></div>';
        messagesEl.appendChild(div);
        messagesEl.scrollTop = messagesEl.scrollHeight;
      }

      function removeTyping() {
        var el = document.getElementById('typing-indicator');
        if (el) el.remove();
      }

      function escapeHtml(text) {
        var d = document.createElement('div');
        d.textContent = text;
        return d.innerHTML;
      }

      function setLoading(loading) {
        isStreaming = loading;
        if (submitBtn) {
          submitBtn.disabled = loading;
          submitBtn.style.opacity = loading ? '0.5' : '1';
        }
        input.disabled = loading;
      }

      async function sendMessage(text) {
        if (!text.trim() || isStreaming) return;

        // Hide quick replies
        var qr = document.getElementById('chat-quick-replies');
        if (qr) qr.remove();

        addUserMessage(text);
        input.value = '';
        chatHistory.push({ role: 'user', content: text });
        saveState();

        setLoading(true);
        showTyping();

        try {
          var response = await fetch('/api/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ messages: chatHistory }),
          });

          removeTyping();

          if (!response.ok) throw new Error('API error');

          var botTextEl = createBotMessage();
          var fullText = '';

          // Read text stream
          var reader = response.body.getReader();
          var decoder = new TextDecoder();

          while (true) {
            var result = await reader.read();
            if (result.done) break;

            var chunk = decoder.decode(result.value, { stream: true });
            fullText += chunk;
            // Renderizamos markdown en vivo (ocultando el marcador [[GOTO:...]],
            // que siempre va al final) para que el formato aparezca progresivo
            // y no de golpe al terminar.
            botTextEl.innerHTML = renderMarkdown(fullText.split('[[')[0]);
            messagesEl.scrollTop = messagesEl.scrollHeight;
          }

          // Separamos la accion de navegacion del texto visible
          var nav = extractNavigation(fullText);
          // Salvaguarda: si solo vino el marcador, ponemos un texto natural.
          if (!nav.clean && nav.route) nav.clean = 'Te llevo allí 👇';
          botTextEl.innerHTML = renderMarkdown(nav.clean);
          scrollToBottom();

          chatHistory.push({ role: 'assistant', content: nav.clean });

          // Keep history manageable (last 10 messages)
          if (chatHistory.length > 10) {
            chatHistory = chatHistory.slice(-10);
          }
          saveState();

          // Navegacion asistida: el agente lleva al usuario donde pidio.
          if (nav.route) {
            var ok = runNavigation(nav.route);
            if (!ok) {
              // La navegacion fallo (ruta/seccion no valida): no dejamos al
              // usuario colgado, ofrecemos seguir por aqui.
              var fb = createBotMessage();
              fb.innerHTML = renderMarkdown('No he podido abrir esa sección, pero te ayudo por aquí. ¿Qué necesitas exactamente? 🙂');
              chatHistory.push({ role: 'assistant', content: 'No he podido abrir esa sección, pero te ayudo por aquí. ¿Qué necesitas exactamente?' });
              scrollToBottom();
            }
          }

        } catch (err) {
          removeTyping();
          var errorEl = createBotMessage();
          errorEl.textContent = 'Lo siento, ha ocurrido un error. Puedes contactarnos directamente al 637 59 17 36 o por WhatsApp.';
        }

        setLoading(false);
      }

      form.addEventListener('submit', function(e) {
        e.preventDefault();
        sendMessage(input.value);
      });

      quickReplies.forEach(function(btn) {
        btn.addEventListener('click', function() {
          sendMessage(btn.textContent.trim());
        });
      });

      // Restaurar conversacion previa tras navegar entre paginas
      (function restore() {
        var raw;
        try { raw = sessionStorage.getItem(STORAGE_KEY); } catch (e) { return; }
        if (!raw) return;
        var state;
        try { state = JSON.parse(raw); } catch (e) { return; }

        if (state.history && state.history.length) {
          var qr = document.getElementById('chat-quick-replies');
          if (qr) qr.remove();
          state.history.forEach(function(msg) {
            if (msg.role === 'user') {
              addUserMessage(msg.content);
            } else if (msg.role === 'assistant') {
              var el = createBotMessage();
              el.innerHTML = renderMarkdown(msg.content);
            }
          });
          chatHistory = state.history;
          scrollToBottom();
        }
        if (state.open) {
          isOpen = false;
          toggleChat();
          scrollToBottom();
        }
      })();

      // Teaser: burbuja que invita a usar el bot, con mensajes rotativos.
      (function setupTeaser() {
        var teaser = document.getElementById('chat-teaser');
        var teaserClose = document.getElementById('chat-teaser-close');
        var teaserText = document.getElementById('chat-teaser-text');
        if (!teaser || !teaserText) return;
        var dismissed = false;
        try { dismissed = sessionStorage.getItem('isbot-teaser') === '1'; } catch (e) {}
        if (dismissed) return;

        var mensajes = [
          '¡Hola! ¿Te ayudo a encontrar lo que buscas?',
          'Te guío por nuestros servicios y reformas.',
          '¿Necesitas presupuesto? Pregúntame.',
          'Dime qué buscas y te llevo a la sección.'
        ];
        var idx = 0;
        var rotTimer;
        teaserText.style.transition = 'opacity .2s ease';

        function hideTeaser() {
          teaser.classList.add('hidden');
          if (rotTimer) clearInterval(rotTimer);
        }
        function dismissTeaser() {
          hideTeaser();
          try { sessionStorage.setItem('isbot-teaser', '1'); } catch (e) {}
        }
        function showTeaser() {
          if (isOpen) return;
          teaser.classList.remove('hidden');
          rotTimer = setInterval(function () {
            if (isOpen) return;
            idx = (idx + 1) % mensajes.length;
            teaserText.style.opacity = '0';
            setTimeout(function () {
              teaserText.textContent = mensajes[idx];
              teaserText.style.opacity = '1';
            }, 250);
          }, 8000);
        }

        setTimeout(function () { if (!isOpen) showTeaser(); }, 5000);

        teaser.addEventListener('click', function (e) {
          if (e.target.closest('#chat-teaser-close')) return;
          dismissTeaser();
          if (!isOpen) toggleChat();
        });
        teaserClose.addEventListener('click', function (e) {
          e.stopPropagation();
          dismissTeaser();
        });
      })();

      // Tras aterrizar por navegacion asistida, resaltamos la seccion (y la
      // zona concreta, si la habia) para dar contexto visual al usuario.
      (function pendingFocus() {
        var zona;
        try { zona = sessionStorage.getItem('isbot-zona'); sessionStorage.removeItem('isbot-zona'); } catch (e) {}
        var hash = window.location.hash ? window.location.hash.substring(1) : '';
        if (hash) {
          var sec = document.getElementById(hash);
          if (sec) setTimeout(function () { focusSection(sec); }, 500);
        }
        if (zona) setTimeout(function () { highlightZona(zona); }, 800);
      })();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initChat);
    } else {
      initChat();
    }
    document.addEventListener('astro:page-load', initChat);
  })();
</script>
