---
import { Icon } from "astro-icon/components";

const services = [
  {
    icon: "lucide:zap",
    color: "text-amber-500",
    bgColor: "bg-amber-50",
    borderAccent: "border-l-amber-500",
    title: "Averías Eléctricas",
    description: "Cortocircuitos, fallos de luz, cuadros eléctricos y cableado defectuoso.",
  },
  {
    icon: "lucide:droplets",
    color: "text-blue-500",
    bgColor: "bg-blue-50",
    borderAccent: "border-l-blue-500",
    title: "Fugas de Agua",
    description: "Goteras, tuberías rotas, desatascos y problemas de presión.",
  },
  {
    icon: "lucide:snowflake",
    color: "text-cyan-500",
    bgColor: "bg-cyan-50",
    borderAccent: "border-l-cyan-500",
    title: "Climatización",
    description: "Reparación de aire acondicionado, calefacción y ventilación.",
  },
];
---

<section class="py-16 md:py-20 border-b border-primary/20">
  <div class="container mx-auto px-4">
    <div class="max-w-5xl mx-auto">

      {/* Header */}
      <div class="text-center mb-12">
        <div data-animate="fade-up" class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-sm font-medium mb-4">
          <Icon name="lucide:wrench" class="w-4 h-4" />
          Servicio técnico profesional
        </div>
        <h2 data-animate="fade-up" class="text-3xl md:text-4xl font-bold mb-4">
          ¿Necesitas un Técnico en Barcelona?
        </h2>
        <p data-animate="fade-up" data-delay="200" class="text-lg text-gray-600 max-w-2xl mx-auto">
          Resolvemos cualquier incidencia en tu hogar o negocio. Técnicos autorizados con respuesta rápida en Barcelona y área metropolitana.
        </p>
      </div>

      {/* Service cards */}
      <div data-stagger class="grid md:grid-cols-3 gap-6 mb-12">
        {
          services.map((service) => (
            <div
              data-animate="fade-up"
              class={`cta-service-card bg-white p-6 rounded-2xl shadow-md border border-primary/20 hover:border-primary/40 hover:shadow-xl group relative overflow-hidden border-l-4 ${service.borderAccent}`}
            >
              <div class="cta-stat-shine"></div>
              <div class="relative z-[1]">
                <div class={`w-12 h-12 ${service.bgColor} rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300`}>
                  <Icon
                    name={service.icon}
                    class={`w-6 h-6 ${service.color}`}
                  />
                </div>
                <h3 class="font-bold text-lg mb-2 text-slate-800 group-hover:text-primary transition-colors duration-300">
                  {service.title}
                </h3>
                <p class="text-gray-600 text-sm leading-relaxed">
                  {service.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>

      {/* Inline CTA - simple, no repetir banner verde */}
      <div data-animate="fade-up" class="text-center">
        <p class="text-gray-600 mb-6 max-w-2xl mx-auto">
          Cuéntanos tu problema y te daremos una solución rápida. <strong>Presupuesto gratuito</strong> y sin compromiso para cualquier incidencia en Barcelona y alrededores.
        </p>
        <a
          href="#contacto"
          class="cta-service-card inline-flex items-center gap-2 bg-primary text-white px-8 py-4 rounded-2xl font-semibold shadow-md border border-primary/20 hover:bg-secondary hover:shadow-xl relative overflow-hidden"
        >
          <div class="cta-stat-shine"></div>
          <Icon name="lucide:file-text" class="w-5 h-5 relative z-[1]" />
          <span class="relative z-[1]">Solicitar Presupuesto Gratis</span>
        </a>
      </div>
    </div>
  </div>
</section>
